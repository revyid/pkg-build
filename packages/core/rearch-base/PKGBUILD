# Maintainer: REArch Team <admin@revy.my.id>
pkgname=rearch-base
pkgver=1.0.0
pkgrel=1
pkgdesc="Base system configuration for ReArch OS"
arch=('any')
url="https://arch.revy.my.id"
license=('MIT')
depends=(
    'rearch-keyring'
    'rearch-hooks'
    'rearch-shell-tools'
)
optdepends=(
    'rearch-welcome: GUI welcome application'
    'rearch-theme-engine: Theme management'
)
install=rearch-base.install
source=('rearch-base.install')

package() {
    # Create os-release
    install -dm755 "$pkgdir/etc"
    cat > "$pkgdir/etc/os-release" << 'EOF'
NAME="ReArch OS"
PRETTY_NAME="ReArch OS"
ID=rearch
ID_LIKE=arch
BUILD_ID=rolling
ANSI_COLOR="0;36"
HOME_URL="https://arch.revy.my.id"
DOCUMENTATION_URL="https://github.com/revyid/rearch-os/wiki"
SUPPORT_URL="https://github.com/revyid/rearch-os/issues"
BUG_REPORT_URL="https://github.com/revyid/rearch-os/issues"
LOGO=rearch
EOF
    
    # Create MOTD
    install -dm755 "$pkgdir/etc"
    cat > "$pkgdir/etc/motd" << 'EOF'
    ____  _______    ____             __
   / __ \/ ___/ /   / __ \____ ______/ /_
  / /_/ / /  / /   / /_/ / __ `/ ___/ __ \
 / _, _/ /__/ /___/ _, _/ /_/ (__  ) / / /
/_/ |_|\____/_____/_/ |_|\__,_/____/_/ /_/

Welcome to ReArch OS!
Documentation: https://arch.revy.my.id
GitHub: https://github.com/revyid/rearch-os

Type 'rearch-fetch' to see system information.
Type 'rearch-setup' to configure your system.
EOF
    
    # Create sysctl configuration
    install -dm755 "$pkgdir/etc/sysctl.d"
    cat > "$pkgdir/etc/sysctl.d/99-rearch.conf" << 'EOF'
# ReArch OS Kernel Parameters

# Network optimizations
net.core.rmem_max = 134217728
net.core.wmem_max = 134217728
net.ipv4.tcp_rmem = 4096 87380 134217728
net.ipv4.tcp_wmem = 4096 65536 134217728
net.core.netdev_max_backlog = 30000
net.ipv4.tcp_congestion_control = bbr
net.ipv4.tcp_fastopen = 3

# Memory management
vm.swappiness=10
vm.vfs_cache_pressure=50
vm.dirty_ratio=10
vm.dirty_background_ratio=5

# Security
kernel.dmesg_restrict = 1
kernel.kptr_restrict = 2
EOF
    
    # Create pacman hook directory
    install -dm755 "$pkgdir/etc/pacman.d/hooks"
    
    # Create snapper pre/post hooks
    cat > "$pkgdir/etc/pacman.d/hooks/95-snapper-pre.hook" << 'EOF'
[Trigger]
Operation = Upgrade
Operation = Install
Operation = Remove
Type = Path
Target = usr/

[Action]
Depends = snapper
When = PreTransaction
Exec = /usr/bin/snapper -c root create -d "Before pacman transaction"
EOF
    
    cat > "$pkgdir/etc/pacman.d/hooks/95-snapper-post.hook" << 'EOF'
[Trigger]
Operation = Upgrade
Operation = Install
Operation = Remove
Type = Path
Target = usr/

[Action]
Depends = snapper
When = PostTransaction
Exec = /usr/bin/snapper -c root create -d "After pacman transaction"
EOF
}
