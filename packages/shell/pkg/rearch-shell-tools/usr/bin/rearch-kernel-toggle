#!/bin/bash
#
# rearch-kernel-toggle - Easy kernel switcher for ReArch OS
# Switch between Zen, LTS, Mainline, and Hardened kernels on the fly
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Available kernels
declare -A KERNELS
KERNELS["linux"]="Standard Arch Linux kernel"
KERNELS["linux-lts"]="Long-term support kernel (stable)"
KERNELS["linux-zen"]="Desktop-optimized kernel"
KERNELS["linux-hardened"]="Security-focused kernel"
KERNELS["linux-rt"]="Real-time kernel"
KERNELS["linux-xanmod"]="Gaming-optimized kernel (AUR)"
KERNELS["linux-liquorix"]="Low-latency kernel (AUR)"

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  _  ___ _   _ ___  ___   _   ___ ___ ___ ___
 | |/ / | | | | _ \/ __| /_\ | _ \_ _| __| __|
 | ' <| |_| |   /\__ \/ _ \|   /| || _|| _|
 |_|\_\\___/|_|_\|___/_/ \_\_|_\___|_| |___|___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Kernel Switcher for ReArch OS${NC}\n"
}

# Get currently running kernel
get_current_kernel() {
    uname -r | cut -d- -f1-2 | sed 's/-ARCH$//; s/-arch$//'
}

# Get default kernel from GRUB
get_default_kernel() {
    if [[ -f /etc/default/grub ]]; then
        grep "GRUB_DEFAULT" /etc/default/grub | cut -d= -f2 | tr -d '"' || echo "0"
    else
        echo "0"
    fi
}

# List installed kernels
list_installed_kernels() {
    log_section "Installed Kernels"
    
    local current=$(get_current_kernel)
    local default_entry=$(get_default_kernel)
    
    echo -e "${BOLD}Kernel                    | Status      | Description${NC}"
    echo "--------------------------|-------------|--------------------------------"
    
    for kernel in "${!KERNELS[@]}"; do
        if pacman -Q "$kernel" &>/dev/null; then
            local status=""
            local version=$(pacman -Q "$kernel" 2>/dev/null | awk '{print $2}')
            
            # Check if currently running
            if [[ "$current" == *"$kernel"* ]] || [[ "$kernel" == "linux" && "$current" != *"-"* ]]; then
                status="${GREEN}● Running${NC}"
            else
                status="${YELLOW}○ Installed${NC}"
            fi
            
            printf "%-25s | %-11b | %s\n" "$kernel ($version)" "$status" "${KERNELS[$kernel]}"
        fi
    done
    echo ""
}

# List available kernels
list_available_kernels() {
    log_section "Available Kernels"
    
    echo -e "${BOLD}Kernel                    | Installed | Description${NC}"
    echo "--------------------------|-----------|--------------------------------"
    
    for kernel in "${!KERNELS[@]}"; do
        local installed=""
        if pacman -Q "$kernel" &>/dev/null; then
            installed="${GREEN}Yes${NC}"
        else
            installed="${RED}No${NC}"
        fi
        
        printf "%-25s | %-9b | %s\n" "$kernel" "$installed" "${KERNELS[$kernel]}"
    done
    echo ""
}

# Install kernel
install_kernel() {
    local kernel="$1"
    
    log_section "Installing $kernel"
    
    # Check if already installed
    if pacman -Q "$kernel" &>/dev/null; then
        log_warn "$kernel is already installed"
        return
    fi
    
    # Check if AUR package
    if [[ "$kernel" == "linux-xanmod" ]] || [[ "$kernel" == "linux-liquorix" ]]; then
        log_info "This kernel is from AUR"
        
        # Detect AUR helper
        local aur_helper=""
        command -v yay &>/dev/null && aur_helper="yay"
        command -v paru &>/dev/null && aur_helper="paru"
        
        if [[ -z "$aur_helper" ]]; then
            log_error "No AUR helper found. Install yay or paru first."
            return 1
        fi
        
        log_info "Installing with $aur_helper..."
        $aur_helper -S "$kernel" "$kernel-headers"
    else
        # Official repository package
        sudo pacman -S "$kernel" "$kernel-headers"
    fi
    
    log_success "$kernel installed successfully"
}

# Remove kernel
remove_kernel() {
    local kernel="$1"
    local current=$(get_current_kernel)
    
    log_section "Removing $kernel"
    
    # Safety check: don't remove running kernel
    if [[ "$current" == *"$kernel"* ]] || [[ "$kernel" == "linux" && "$current" != *"-"* ]]; then
        log_error "Cannot remove the currently running kernel!"
        log_info "Please boot into a different kernel first."
        return 1
    fi
    
    # Check if installed
    if ! pacman -Q "$kernel" &>/dev/null; then
        log_warn "$kernel is not installed"
        return
    fi
    
    # Remove kernel
    sudo pacman -Rns "$kernel" "$kernel-headers"
    
    log_success "$kernel removed successfully"
}

# Set default kernel
set_default_kernel() {
    local kernel="$1"
    
    log_section "Setting Default Kernel"
    
    # Find kernel entry in GRUB
    local menu_entries=$(grep -E "^menuentry|^submenu" /boot/grub/grub.cfg 2>/dev/null | grep -n "" || true)
    local target_entry=""
    
    # Find the entry for the selected kernel
    case "$kernel" in
        linux)
            target_entry=$(echo "$menu_entries" | grep -i "arch linux" | grep -vi "lts\|zen\|hardened" | head -1 | cut -d: -f1)
            ;;
        linux-lts)
            target_entry=$(echo "$menu_entries" | grep -i "lts" | head -1 | cut -d: -f1)
            ;;
        linux-zen)
            target_entry=$(echo "$menu_entries" | grep -i "zen" | head -1 | cut -d: -f1)
            ;;
        linux-hardened)
            target_entry=$(echo "$menu_entries" | grep -i "hardened" | head -1 | cut -d: -f1)
            ;;
        *)
            target_entry=$(echo "$menu_entries" | grep -i "$kernel" | head -1 | cut -d: -f1)
            ;;
    esac
    
    if [[ -z "$target_entry" ]]; then
        log_error "Could not find GRUB entry for $kernel"
        log_info "You may need to regenerate GRUB config first: sudo grub-mkconfig -o /boot/grub/grub.cfg"
        return 1
    fi
    
    # Convert to zero-based index
    target_entry=$((target_entry - 1))
    
    # Update GRUB default
    sudo sed -i "s/^GRUB_DEFAULT=.*/GRUB_DEFAULT=$target_entry/" /etc/default/grub
    sudo grub-mkconfig -o /boot/grub/grub.cfg
    
    log_success "Default kernel set to $kernel"
    log_info "The system will boot into $kernel on next restart"
}

# Show kernel info
show_kernel_info() {
    log_section "Kernel Information"
    
    echo -e "${BOLD}Current Kernel:${NC}"
    echo "  Version:    $(uname -r)"
    echo "  Release:    $(uname -v)"
    echo "  Machine:    $(uname -m)"
    echo ""
    
    echo -e "${BOLD}Kernel Parameters:${NC}"
    cat /proc/cmdline | fold -s -w 70 | sed 's/^/  /'
    echo ""
    
    echo -e "${BOLD}Loaded Modules:${NC}"
    lsmod | wc -l | xargs echo "  Count:"
    echo ""
    
    echo -e "${BOLD}Kernel Boot Time:${NC}"
    systemd-analyze 2>/dev/null | sed 's/^/  /' || echo "  N/A"
    echo ""
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        list_installed_kernels
        
        echo "Options:"
        echo "1) Install a kernel"
        echo "2) Remove a kernel"
        echo "3) Set default kernel"
        echo "4) Show kernel info"
        echo "5) Regenerate GRUB config"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1)
                list_available_kernels
                read -rp "Enter kernel name to install: " kernel
                install_kernel "$kernel"
                read -n1 -rp "Press any key to continue..."
                ;;
            2)
                read -rp "Enter kernel name to remove: " kernel
                remove_kernel "$kernel"
                read -n1 -rp "Press any key to continue..."
                ;;
            3)
                read -rp "Enter kernel name to set as default: " kernel
                set_default_kernel "$kernel"
                read -n1 -rp "Press any key to continue..."
                ;;
            4)
                show_kernel_info
                read -n1 -rp "Press any key to continue..."
                ;;
            5)
                log_info "Regenerating GRUB config..."
                sudo grub-mkconfig -o /boot/grub/grub.cfg
                log_success "GRUB config regenerated"
                read -n1 -rp "Press any key to continue..."
                ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-kernel-toggle [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  list              List installed kernels"
    echo "  available         List available kernels"
    echo "  install KERNEL    Install a kernel"
    echo "  remove KERNEL     Remove a kernel"
    echo "  default KERNEL    Set default kernel"
    echo "  info              Show kernel information"
    echo "  interactive       Interactive menu (default)"
    echo ""
    echo "Available kernels:"
    for kernel in "${!KERNELS[@]}"; do
        echo "  - $kernel: ${KERNELS[$kernel]}"
    done
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        list)
            list_installed_kernels
            ;;
        available)
            list_available_kernels
            ;;
        install)
            if [[ -z "$2" ]]; then
                log_error "Please specify a kernel name"
                usage
                exit 1
            fi
            install_kernel "$2"
            ;;
        remove)
            if [[ -z "$2" ]]; then
                log_error "Please specify a kernel name"
                usage
                exit 1
            fi
            remove_kernel "$2"
            ;;
        default)
            if [[ -z "$2" ]]; then
                log_error "Please specify a kernel name"
                usage
                exit 1
            fi
            set_default_kernel "$2"
            ;;
        info)
            show_kernel_info
            ;;
        interactive)
            interactive_menu
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            log_error "Unknown command: $1"
            usage
            exit 1
            ;;
    esac
}

main "$@"
