#!/bin/bash
#
# rearch-check - Comprehensive system health diagnostic tool for ReArch OS
# Checks disk health, RAM, failed systemd units, and system integrity
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
VERBOSE=false
CHECK_DISK=true
CHECK_RAM=true
CHECK_SYSTEMD=true
CHECK_SECURITY=true
CHECK_NETWORK=true
CHECK_TEMPERATURE=true

# Results tracking
declare -A CHECK_RESULTS
ISSUES_FOUND=0
WARNINGS_FOUND=0

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
   ___ _   _ ___  ___   _   _  ___ _____
  / __| | | | _ \/ __| | | | |/ __|_   _|
 | (__| |_| |   /\__ \ | |_| | (__  | |
  \___|\___/|_|_\|___/  \___/ \___| |_|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}System Health Diagnostic for ReArch OS${NC}\n"
}

# Check disk health
check_disk_health() {
    log_section "Disk Health Check"
    
    # Check disk usage
    log_info "Checking disk usage..."
    local disk_usage=$(df -h / | tail -1 | awk '{print $5}' | tr -d '%')
    
    if [[ $disk_usage -ge 90 ]]; then
        log_error "Root filesystem is ${disk_usage}% full!"
        CHECK_RESULTS["disk_usage"]="CRITICAL"
        ((ISSUES_FOUND++))
    elif [[ $disk_usage -ge 80 ]]; then
        log_warn "Root filesystem is ${disk_usage}% full"
        CHECK_RESULTS["disk_usage"]="WARNING"
        ((WARNINGS_FOUND++))
    else
        log_success "Root filesystem is ${disk_usage}% full"
        CHECK_RESULTS["disk_usage"]="OK"
    fi
    
    # Check for disk errors in dmesg
    if dmesg 2>/dev/null | grep -i "error\|fail\|corrupt" | grep -qi "disk\|sda\|nvme\|block"; then
        log_warn "Disk errors found in system logs"
        CHECK_RESULTS["disk_errors"]="WARNING"
        ((WARNINGS_FOUND++))
    else
        log_success "No disk errors in system logs"
        CHECK_RESULTS["disk_errors"]="OK"
    fi
    
    # Check filesystem integrity (read-only check)
    log_info "Checking filesystem integrity..."
    if command -v btrfs &>/dev/null && mount | grep -q "btrfs"; then
        local btrfs_dev=$(findmnt -n -o SOURCE / 2>/dev/null || echo "")
        if [[ -n "$btrfs_dev" ]]; then
            if sudo btrfs device stats "$btrfs_dev" 2>/dev/null | grep -v "0" | grep -q "[1-9]"; then
                log_warn "Btrfs device stats show errors"
                CHECK_RESULTS["btrfs_stats"]="WARNING"
                ((WARNINGS_FOUND++))
            else
                log_success "Btrfs filesystem healthy"
                CHECK_RESULTS["btrfs_stats"]="OK"
            fi
        fi
    fi
    
    # Check SMART status for physical disks
    if command -v smartctl &>/dev/null; then
        log_info "Checking SMART status..."
        for disk in /dev/sd[a-z] /dev/nvme[0-9]n1 2>/dev/null; do
            [[ -e "$disk" ]] || continue
            local smart_status=$(sudo smartctl -H "$disk" 2>/dev/null | grep "SMART overall-health" | awk '{print $6}')
            if [[ "$smart_status" == "FAILED" ]]; then
                log_error "SMART check FAILED for $disk!"
                CHECK_RESULTS["smart_$disk"]="CRITICAL"
                ((ISSUES_FOUND++))
            elif [[ "$smart_status" == "PASSED" ]]; then
                log_success "SMART check passed for $disk"
                CHECK_RESULTS["smart_$disk"]="OK"
            fi
        done
    fi
    
    # Check for read-only filesystems
    if mount | grep -q "on / type.*ro,"; then
        log_error "Root filesystem is read-only!"
        CHECK_RESULTS["fs_readonly"]="CRITICAL"
        ((ISSUES_FOUND++))
    fi
}

# Check RAM health
check_ram_health() {
    log_section "Memory Health Check"
    
    # Get memory info
    local mem_info=$(free -m | grep "^Mem:")
    local total=$(echo "$mem_info" | awk '{print $2}')
    local used=$(echo "$mem_info" | awk '{print $3}')
    local available=$(echo "$mem_info" | awk '{print $7}')
    local usage_percent=$((used * 100 / total))
    
    log_info "Memory: ${used}MB / ${total}MB (${usage_percent}% used)"
    
    if [[ $usage_percent -ge 95 ]]; then
        log_error "Memory usage is critically high (${usage_percent}%)!"
        CHECK_RESULTS["memory_usage"]="CRITICAL"
        ((ISSUES_FOUND++))
    elif [[ $usage_percent -ge 85 ]]; then
        log_warn "Memory usage is high (${usage_percent}%)"
        CHECK_RESULTS["memory_usage"]="WARNING"
        ((WARNINGS_FOUND++))
    else
        log_success "Memory usage is normal (${usage_percent}%)"
        CHECK_RESULTS["memory_usage"]="OK"
    fi
    
    # Check swap usage
    local swap_info=$(free -m | grep "^Swap:")
    local swap_total=$(echo "$swap_info" | awk '{print $2}')
    local swap_used=$(echo "$swap_info" | awk '{print $3}')
    
    if [[ $swap_total -gt 0 ]]; then
        local swap_percent=$((swap_used * 100 / swap_total))
        if [[ $swap_percent -ge 80 ]]; then
            log_warn "Swap usage is high (${swap_percent}%)"
            CHECK_RESULTS["swap_usage"]="WARNING"
            ((WARNINGS_FOUND++))
        else
            log_success "Swap usage is normal (${swap_percent}%)"
            CHECK_RESULTS["swap_usage"]="OK"
        fi
    fi
    
    # Check for OOM kills
    local oom_kills=$(dmesg 2>/dev/null | grep -c "Out of memory" || echo 0)
    if [[ $oom_kills -gt 0 ]]; then
        log_warn "Found $oom_kills OOM kills in system logs"
        CHECK_RESULTS["oom_kills"]="WARNING"
        ((WARNINGS_FOUND++))
    else
        log_success "No OOM kills found"
        CHECK_RESULTS["oom_kills"]="OK"
    fi
    
    # Check for memory errors in EDAC (if available)
    if [[ -d /sys/devices/system/edac ]]; then
        local mem_errors=$(find /sys/devices/system/edac -name "*ce_count" -exec cat {} \; 2>/dev/null | awk '{sum+=$1} END {print sum}')
        if [[ -n "$mem_errors" ]] && [[ "$mem_errors" -gt 0 ]]; then
            log_warn "Found $mem_errors memory errors (EDAC)"
            CHECK_RESULTS["memory_errors"]="WARNING"
            ((WARNINGS_FOUND++))
        fi
    fi
}

# Check systemd units
check_systemd_units() {
    log_section "Systemd Services Check"
    
    # Check for failed units
    local failed_units=$(systemctl --failed --no-legend --no-pager 2>/dev/null | grep "failed" | awk '{print $2}' || true)
    local failed_count=$(echo "$failed_units" | grep -c "^" || echo 0)
    
    if [[ $failed_count -gt 0 ]]; then
        log_error "Found $failed_count failed systemd unit(s):"
        echo "$failed_units" | head -10 | while read -r unit; do
            log_error "  - $unit"
        done
        CHECK_RESULTS["systemd_failed"]="CRITICAL"
        ((ISSUES_FOUND++))
    else
        log_success "No failed systemd units"
        CHECK_RESULTS["systemd_failed"]="OK"
    fi
    
    # Check for degraded system state
    local system_state=$(systemctl is-system-running 2>/dev/null || echo "unknown")
    if [[ "$system_state" == "degraded" ]]; then
        log_warn "System state is degraded"
        CHECK_RESULTS["system_state"]="WARNING"
        ((WARNINGS_FOUND++))
    elif [[ "$system_state" == "running" ]]; then
        log_success "System state is running"
        CHECK_RESULTS["system_state"]="OK"
    fi
    
    # Check for services stuck in activating/deactivating state
    local stuck_services=$(systemctl list-units --state=activating,deactivating --no-legend --no-pager 2>/dev/null | wc -l)
    if [[ $stuck_services -gt 0 ]]; then
        log_warn "Found $stuck_services service(s) stuck in transition"
        CHECK_RESULTS["stuck_services"]="WARNING"
        ((WARNINGS_FOUND++))
    fi
    
    # Check for timers that failed to run
    local failed_timers=$(systemctl list-timers --failed --no-legend --no-pager 2>/dev/null | wc -l)
    if [[ $failed_timers -gt 0 ]]; then
        log_warn "Found $failed_timers failed timer(s)"
        CHECK_RESULTS["failed_timers"]="WARNING"
        ((WARNINGS_FOUND++))
    fi
}

# Check security
check_security() {
    log_section "Security Check"
    
    # Check if firewall is active
    if command -v firewall-cmd &>/dev/null; then
        if firewall-cmd --state 2>/dev/null | grep -q "running"; then
            log_success "Firewall (firewalld) is active"
            CHECK_RESULTS["firewall"]="OK"
        else
            log_warn "Firewall (firewalld) is not running"
            CHECK_RESULTS["firewall"]="WARNING"
            ((WARNINGS_FOUND++))
        fi
    elif command -v ufw &>/dev/null; then
        if ufw status 2>/dev/null | grep -q "Status: active"; then
            log_success "Firewall (ufw) is active"
            CHECK_RESULTS["firewall"]="OK"
        else
            log_warn "Firewall (ufw) is not active"
            CHECK_RESULTS["firewall"]="WARNING"
            ((WARNINGS_FOUND++))
        fi
    fi
    
    # Check for AppArmor
    if [[ -d /sys/kernel/security/apparmor ]]; then
        if cat /sys/kernel/security/apparmor/profiles 2>/dev/null | grep -q ":"; then
            log_success "AppArmor is active"
            CHECK_RESULTS["apparmor"]="OK"
        else
            log_warn "AppArmor is not enforcing profiles"
            CHECK_RESULTS["apparmor"]="WARNING"
            ((WARNINGS_FOUND++))
        fi
    fi
    
    # Check for SELinux (if installed)
    if command -v getenforce &>/dev/null; then
        local selinux_status=$(getenforce 2>/dev/null)
        if [[ "$selinux_status" == "Enforcing" ]]; then
            log_success "SELinux is enforcing"
            CHECK_RESULTS["selinux"]="OK"
        elif [[ "$selinux_status" == "Permissive" ]]; then
            log_warn "SELinux is in permissive mode"
            CHECK_RESULTS["selinux"]="WARNING"
            ((WARNINGS_FOUND++))
        fi
    fi
    
    # Check for pending security updates
    log_info "Checking for security updates..."
    local security_updates=$(pacman -Qu 2>/dev/null | grep -iE "linux|systemd|openssl|openssh|glibc" | wc -l)
    if [[ $security_updates -gt 0 ]]; then
        log_warn "Found $security_updates pending security-related updates"
        CHECK_RESULTS["security_updates"]="WARNING"
        ((WARNINGS_FOUND++))
    else
        log_success "No critical security updates pending"
        CHECK_RESULTS["security_updates"]="OK"
    fi
    
    # Check for world-writable directories
    local world_writable=$(find / -xdev -type d -perm -0002 ! -perm -1000 2>/dev/null | head -10)
    if [[ -n "$world_writable" ]]; then
        log_warn "Found world-writable directories without sticky bit"
        CHECK_RESULTS["world_writable"]="WARNING"
        ((WARNINGS_FOUND++))
    fi
    
    # Check for SUID files
    log_info "Checking SUID files..."
    local suid_files=$(find / -xdev -perm -4000 -type f 2>/dev/null | wc -l)
    log_info "Found $suid_files SUID files"
}

# Check network
check_network() {
    log_section "Network Check"
    
    # Check internet connectivity
    if ping -c 1 -W 5 1.1.1.1 &>/dev/null; then
        log_success "Internet connectivity OK"
        CHECK_RESULTS["internet"]="OK"
    else
        log_error "No internet connectivity"
        CHECK_RESULTS["internet"]="CRITICAL"
        ((ISSUES_FOUND++))
    fi
    
    # Check DNS resolution
    if nslookup archlinux.org &>/dev/null; then
        log_success "DNS resolution OK"
        CHECK_RESULTS["dns"]="OK"
    else
        log_warn "DNS resolution failed"
        CHECK_RESULTS["dns"]="WARNING"
        ((WARNINGS_FOUND++))
    fi
    
    # Check for listening services
    local listening_ports=$(ss -tlnp 2>/dev/null | grep LISTEN | wc -l)
    log_info "Found $listening_ports listening port(s)"
    
    # Check NetworkManager
    if systemctl is-active NetworkManager &>/dev/null; then
        log_success "NetworkManager is running"
        CHECK_RESULTS["networkmanager"]="OK"
    else
        log_warn "NetworkManager is not running"
        CHECK_RESULTS["networkmanager"]="WARNING"
        ((WARNINGS_FOUND++))
    fi
}

# Check temperatures
check_temperatures() {
    log_section "Temperature Check"
    
    if command -v sensors &>/dev/null; then
        local sensors_output=$(sensors 2>/dev/null)
        
        # Check CPU temperature
        local cpu_temp=$(echo "$sensors_output" | grep -E "Core|Package id|Tdie" | head -1 | grep -oP '\+[0-9.]+°C' | head -1 | tr -d '+°C')
        
        if [[ -n "$cpu_temp" ]]; then
            local cpu_temp_int=${cpu_temp%.*}
            log_info "CPU temperature: ${cpu_temp}°C"
            
            if [[ $cpu_temp_int -ge 90 ]]; then
                log_error "CPU temperature is critically high!"
                CHECK_RESULTS["cpu_temp"]="CRITICAL"
                ((ISSUES_FOUND++))
            elif [[ $cpu_temp_int -ge 80 ]]; then
                log_warn "CPU temperature is high"
                CHECK_RESULTS["cpu_temp"]="WARNING"
                ((WARNINGS_FOUND++))
            else
                log_success "CPU temperature is normal"
                CHECK_RESULTS["cpu_temp"]="OK"
            fi
        fi
        
        # Check GPU temperature (if available)
        local gpu_temp=$(echo "$sensors_output" | grep -i "gpu" | grep -oP '\+[0-9.]+°C' | head -1 | tr -d '+°C')
        if [[ -n "$gpu_temp" ]]; then
            log_info "GPU temperature: ${gpu_temp}°C"
        fi
    else
        log_info "lm_sensors not installed, skipping temperature check"
    fi
    
    # Check thermal zones
    for zone in /sys/class/thermal/thermal_zone*/temp 2>/dev/null; do
        [[ -f "$zone" ]] || continue
        local temp=$(cat "$zone" 2>/dev/null)
        if [[ -n "$temp" ]]; then
            local temp_c=$((temp / 1000))
            local zone_name=$(cat "${zone%/*}/type" 2>/dev/null || echo "unknown")
            if [[ $temp_c -ge 80 ]]; then
                log_warn "High temperature in $zone_name: ${temp_c}°C"
            fi
        fi
    done
}

# Check system integrity
check_system_integrity() {
    log_section "System Integrity Check"
    
    # Check for modified system files (if pacman-contrib is installed)
    if command -v paccheck &>/dev/null; then
        log_info "Checking for modified system files..."
        local modified_files=$(paccheck --md5sum --quiet 2>/dev/null | wc -l)
        if [[ $modified_files -gt 0 ]]; then
            log_warn "Found $modified_files modified system file(s)"
            CHECK_RESULTS["file_integrity"]="WARNING"
            ((WARNINGS_FOUND++))
        else
            log_success "All system files intact"
            CHECK_RESULTS["file_integrity"]="OK"
        fi
    fi
    
    # Check for broken symlinks
    log_info "Checking for broken symlinks..."
    local broken_links=$(find /usr -xdev -type l ! -exec test -e {} \; -print 2>/dev/null | wc -l)
    if [[ $broken_links -gt 0 ]]; then
        log_warn "Found $broken_links broken symlink(s)"
        CHECK_RESULTS["broken_links"]="WARNING"
        ((WARNINGS_FOUND++))
    else
        log_success "No broken symlinks found"
        CHECK_RESULTS["broken_links"]="OK"
    fi
    
    # Check for missing firmware
    if dmesg 2>/dev/null | grep -q "firmware.*not found"; then
        log_warn "Missing firmware detected in system logs"
        CHECK_RESULTS["firmware"]="WARNING"
        ((WARNINGS_FOUND++))
    fi
}

# Show summary
show_summary() {
    echo ""
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}${BOLD}  System Health Summary${NC}"
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    
    # Count results
    local ok_count=0
    local warning_count=0
    local critical_count=0
    
    for result in "${CHECK_RESULTS[@]}"; do
        case "$result" in
            OK) ((ok_count++)) ;;
            WARNING) ((warning_count++)) ;;
            CRITICAL) ((critical_count++)) ;;
        esac
    done
    
    echo -e "  ${GREEN}✓ OK:${NC}       $ok_count checks passed"
    echo -e "  ${YELLOW}⚠ Warnings:${NC} $warning_count warnings"
    echo -e "  ${RED}✗ Critical:${NC} $critical_count critical issues"
    echo ""
    
    if [[ $critical_count -gt 0 ]]; then
        echo -e "  ${RED}${BOLD}System health: CRITICAL${NC}"
        echo -e "  ${RED}Please address the critical issues immediately!${NC}"
        exit 2
    elif [[ $warning_count -gt 0 ]]; then
        echo -e "  ${YELLOW}${BOLD}System health: WARNING${NC}"
        echo -e "  ${YELLOW}Some issues need attention.${NC}"
        exit 1
    else
        echo -e "  ${GREEN}${BOLD}System health: EXCELLENT${NC}"
        echo -e "  ${GREEN}Your system is in great shape!${NC}"
        exit 0
    fi
}

# Usage
usage() {
    echo "Usage: rearch-check [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --quick            Run quick checks only"
    echo "  --disk-only        Check disk health only"
    echo "  --ram-only         Check RAM health only"
    echo "  --systemd-only     Check systemd only"
    echo "  --security-only    Check security only"
    echo "  --verbose          Show detailed output"
    echo "  --help, -h         Show this help message"
    echo ""
    echo "Exit codes:"
    echo "  0 - All checks passed"
    echo "  1 - Warnings found"
    echo "  2 - Critical issues found"
}

# Main
main() {
    VERBOSE=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quick)
                CHECK_NETWORK=false
                CHECK_TEMPERATURE=false
                ;;
            --disk-only)
                CHECK_RAM=false; CHECK_SYSTEMD=false; CHECK_SECURITY=false
                CHECK_NETWORK=false; CHECK_TEMPERATURE=false
                ;;
            --ram-only)
                CHECK_DISK=false; CHECK_SYSTEMD=false; CHECK_SECURITY=false
                CHECK_NETWORK=false; CHECK_TEMPERATURE=false
                ;;
            --systemd-only)
                CHECK_DISK=false; CHECK_RAM=false; CHECK_SECURITY=false
                CHECK_NETWORK=false; CHECK_TEMPERATURE=false
                ;;
            --security-only)
                CHECK_DISK=false; CHECK_RAM=false; CHECK_SYSTEMD=false
                CHECK_NETWORK=false; CHECK_TEMPERATURE=false
                ;;
            --verbose) VERBOSE=true ;;
            --help|-h) usage; exit 0 ;;
            *) log_error "Unknown option: $1"; usage; exit 1 ;;
        esac
        shift
    done
    
    show_banner
    
    # Run checks
    [[ "$CHECK_DISK" == true ]] && check_disk_health
    [[ "$CHECK_RAM" == true ]] && check_ram_health
    [[ "$CHECK_SYSTEMD" == true ]] && check_systemd_units
    [[ "$CHECK_SECURITY" == true ]] && check_security
    [[ "$CHECK_NETWORK" == true ]] && check_network
    [[ "$CHECK_TEMPERATURE" == true ]] && check_temperatures
    
    check_system_integrity
    
    show_summary
}

main "$@"
