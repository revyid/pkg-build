#!/bin/bash
#
# rearch-theme - Theme manager for ReArch OS
# Switch global themes (GTK, Icons, Cursor, Kitty, Waybar) simultaneously
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
GTK2_CONFIG="$HOME/.gtkrc-2.0"
GTK3_CONFIG="$HOME/.config/gtk-3.0/settings.ini"
GTK4_CONFIG="$HOME/.config/gtk-4.0/settings.ini"
ICON_DIR="/usr/share/icons"
THEME_DIR="/usr/share/themes"

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  _____ _            _
 |_   _| |_  ___ _ _| |_
   | | | ' \/ -_) '_|  _|
   |_| |_||_\___|_|  \__|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Theme Manager for ReArch OS${NC}\n"
}

# List available themes
list_themes() {
    log_section "Available Themes"
    
    echo -e "${BOLD}GTK Themes:${NC}"
    ls -1 "$THEME_DIR" 2>/dev/null | head -20 | sed 's/^/  /'
    
    echo ""
    echo -e "${BOLD}Icon Themes:${NC}"
    ls -1 "$ICON_DIR" 2>/dev/null | head -20 | sed 's/^/  /'
    
    echo ""
    echo -e "${BOLD}Cursor Themes:${NC}"
    ls -1 "$ICON_DIR" 2>/dev/null | while read -r dir; do
        if [[ -d "$ICON_DIR/$dir/cursors" ]]; then
            echo "  $dir"
        fi
    done | head -10
}

# Get current theme
get_current() {
    log_section "Current Theme Settings"
    
    local gtk_theme=""
    local icon_theme=""
    local cursor_theme=""
    
    # GTK3
    if [[ -f "$GTK3_CONFIG" ]]; then
        gtk_theme=$(grep "gtk-theme-name" "$GTK3_CONFIG" 2>/dev/null | cut -d= -f2)
        icon_theme=$(grep "gtk-icon-theme-name" "$GTK3_CONFIG" 2>/dev/null | cut -d= -f2)
        cursor_theme=$(grep "gtk-cursor-theme-name" "$GTK3_CONFIG" 2>/dev/null | cut -d= -f2)
    fi
    
    echo -e "${BOLD}GTK Theme:${NC}   ${gtk_theme:-Default}"
    echo -e "${BOLD}Icon Theme:${NC}  ${icon_theme:-Default}"
    echo -e "${BOLD}Cursor:${NC}      ${cursor_theme:-Default}"
}

# Set GTK theme
set_gtk_theme() {
    local theme="$1"
    
    if [[ -z "$theme" ]]; then
        log_error "Please specify theme name"
        return 1
    fi
    
    # Create config directories
    mkdir -p "$HOME/.config/gtk-3.0"
    mkdir -p "$HOME/.config/gtk-4.0"
    
    # GTK3
    if [[ -f "$GTK3_CONFIG" ]]; then
        if grep -q "gtk-theme-name" "$GTK3_CONFIG"; then
            sed -i "s/gtk-theme-name=.*/gtk-theme-name=$theme/" "$GTK3_CONFIG"
        else
            echo "gtk-theme-name=$theme" >> "$GTK3_CONFIG"
        fi
    else
        echo "[Settings]" > "$GTK3_CONFIG"
        echo "gtk-theme-name=$theme" >> "$GTK3_CONFIG"
    fi
    
    # GTK4 (copy GTK3 settings)
    cp "$GTK3_CONFIG" "$GTK4_CONFIG"
    
    # GTK2
    if [[ -f "$GTK2_CONFIG" ]]; then
        if grep -q "gtk-theme-name" "$GTK2_CONFIG"; then
            sed -i "s/gtk-theme-name \".*\"/gtk-theme-name \"$theme\"/" "$GTK2_CONFIG"
        else
            echo "gtk-theme-name=\"$theme\"" >> "$GTK2_CONFIG"
        fi
    else
        echo "gtk-theme-name=\"$theme\"" > "$GTK2_CONFIG"
    fi
    
    log_success "GTK theme set to: $theme"
}

# Set icon theme
set_icon_theme() {
    local theme="$1"
    
    if [[ -z "$theme" ]]; then
        log_error "Please specify icon theme name"
        return 1
    fi
    
    mkdir -p "$HOME/.config/gtk-3.0"
    
    if [[ -f "$GTK3_CONFIG" ]]; then
        if grep -q "gtk-icon-theme-name" "$GTK3_CONFIG"; then
            sed -i "s/gtk-icon-theme-name=.*/gtk-icon-theme-name=$theme/" "$GTK3_CONFIG"
        else
            echo "gtk-icon-theme-name=$theme" >> "$GTK3_CONFIG"
        fi
    else
        echo "[Settings]" > "$GTK3_CONFIG"
        echo "gtk-icon-theme-name=$theme" >> "$GTK3_CONFIG"
    fi
    
    cp "$GTK3_CONFIG" "$GTK4_CONFIG"
    
    # GTK2
    if [[ -f "$GTK2_CONFIG" ]]; then
        if grep -q "gtk-icon-theme-name" "$GTK2_CONFIG"; then
            sed -i "s/gtk-icon-theme-name \".*\"/gtk-icon-theme-name \"$theme\"/" "$GTK2_CONFIG"
        else
            echo "gtk-icon-theme-name=\"$theme\"" >> "$GTK2_CONFIG"
        fi
    fi
    
    log_success "Icon theme set to: $theme"
}

# Set cursor theme
set_cursor_theme() {
    local theme="$1"
    
    if [[ -z "$theme" ]]; then
        log_error "Please specify cursor theme name"
        return 1
    fi
    
    mkdir -p "$HOME/.config/gtk-3.0"
    mkdir -p "$HOME/.icons"
    
    # GTK
    if [[ -f "$GTK3_CONFIG" ]]; then
        if grep -q "gtk-cursor-theme-name" "$GTK3_CONFIG"; then
            sed -i "s/gtk-cursor-theme-name=.*/gtk-cursor-theme-name=$theme/" "$GTK3_CONFIG"
        else
            echo "gtk-cursor-theme-name=$theme" >> "$GTK3_CONFIG"
        fi
    else
        echo "[Settings]" > "$GTK3_CONFIG"
        echo "gtk-cursor-theme-name=$theme" >> "$GTK3_CONFIG"
    fi
    
    cp "$GTK3_CONFIG" "$GTK4_CONFIG"
    
    # Create .icons symlink
    if [[ -d "$ICON_DIR/$theme" ]]; then
        ln -sf "$ICON_DIR/$theme" "$HOME/.icons/default" 2>/dev/null || true
    fi
    
    log_success "Cursor theme set to: $theme"
}

# Set Kitty theme
set_kitty_theme() {
    local theme="$1"
    
    if [[ -z "$theme" ]]; then
        log_error "Please specify theme name"
        return 1
    fi
    
    local kitty_conf="$HOME/.config/kitty/kitty.conf"
    
    mkdir -p "$HOME/.config/kitty"
    
    # Check if theme exists in kitty themes
    if [[ -f "/usr/share/kitty-themes/$theme.conf" ]] || [[ -f "$HOME/.config/kitty/themes/$theme.conf" ]]; then
        # Add include to kitty.conf
        if [[ -f "$kitty_conf" ]]; then
            if grep -q "include.*theme" "$kitty_conf"; then
                sed -i "s|include.*theme.*|include themes/$theme.conf|" "$kitty_conf"
            else
                echo "include themes/$theme.conf" >> "$kitty_conf"
            fi
        else
            echo "include themes/$theme.conf" > "$kitty_conf"
        fi
        
        log_success "Kitty theme set to: $theme"
    else
        log_warn "Theme not found in kitty themes"
    fi
}

# Set Waybar theme
set_waybar_theme() {
    local theme="$1"
    
    if [[ -z "$theme" ]]; then
        log_error "Please specify theme name"
        return 1
    fi
    
    local waybar_dir="$HOME/.config/waybar"
    
    if [[ -d "$waybar_dir" ]]; then
        # Backup current config
        if [[ -f "$waybar_dir/style.css" ]]; then
            cp "$waybar_dir/style.css" "$waybar_dir/style.css.backup"
        fi
        
        # Apply theme if exists
        if [[ -f "$waybar_dir/themes/$theme.css" ]]; then
            cp "$waybar_dir/themes/$theme.css" "$waybar_dir/style.css"
            log_success "Waybar theme set to: $theme"
            log_info "Restart waybar to apply changes"
        else
            log_warn "Waybar theme not found: $theme"
        fi
    else
        log_warn "Waybar config directory not found"
    fi
}

# Apply complete theme
apply_theme() {
    local name="$1"
    
    log_section "Applying Theme: $name"
    
    # Define theme presets
    case "$name" in
        dark)
            set_gtk_theme "Arc-Dark"
            set_icon_theme "Papirus-Dark"
            set_cursor_theme "Adwaita"
            ;;
        light)
            set_gtk_theme "Arc"
            set_icon_theme "Papirus"
            set_cursor_theme "Adwaita"
            ;;
        nord)
            set_gtk_theme "Nordic"
            set_icon_theme "Papirus-Dark"
            set_cursor_theme "Nordic-cursors"
            ;;
        dracula)
            set_gtk_theme "Dracula"
            set_icon_theme "Papirus-Dark"
            set_cursor_theme "Dracula-cursors"
            ;;
        *)
            log_error "Unknown theme preset: $name"
            log_info "Available presets: dark, light, nord, dracula"
            return 1
            ;;
    esac
    
    log_success "Theme '$name' applied successfully"
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        get_current
        echo ""
        
        echo "Options:"
        echo "1) List available themes"
        echo "2) Set GTK theme"
        echo "3) Set icon theme"
        echo "4) Set cursor theme"
        echo "5) Apply complete theme"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) list_themes; read -n1 -rp "Press any key..." ;;
            2)
                read -rp "GTK theme name: " theme
                set_gtk_theme "$theme"
                read -n1 -rp "Press any key..."
                ;;
            3)
                read -rp "Icon theme name: " theme
                set_icon_theme "$theme"
                read -n1 -rp "Press any key..."
                ;;
            4)
                read -rp "Cursor theme name: " theme
                set_cursor_theme "$theme"
                read -n1 -rp "Press any key..."
                ;;
            5)
                echo "Presets: dark, light, nord, dracula"
                read -rp "Theme preset: " theme
                apply_theme "$theme"
                read -n1 -rp "Press any key..."
                ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-theme [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  list              List available themes"
    echo "  current           Show current theme"
    echo "  gtk THEME         Set GTK theme"
    echo "  icon THEME        Set icon theme"
    echo "  cursor THEME      Set cursor theme"
    echo "  apply PRESET      Apply complete theme preset"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        list) list_themes ;;
        current) get_current ;;
        gtk) set_gtk_theme "$2" ;;
        icon) set_icon_theme "$2" ;;
        cursor) set_cursor_theme "$2" ;;
        apply) apply_theme "$2" ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
