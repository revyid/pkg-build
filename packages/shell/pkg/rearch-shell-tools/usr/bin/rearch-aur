#!/bin/bash
#
# rearch-aur - AUR helper manager for ReArch OS
# Install and manage AUR helpers
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Available AUR helpers
declare -A HELPERS
HELPERS["yay"]="Yet Another Yogurt - Fast and feature-rich"
HELPERS["paru"]="Feature-rich AUR helper in Rust"
HELPERS["trizen"]="Lightweight AUR helper in Perl"
HELPERS["pikaur"]="AUR helper with dependency resolution"

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
    _   ___  ___
   /_\ | _ \/ __|
  / _ \|   / (__
 /_/ \_\_|_\\___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}AUR Manager for ReArch OS${NC}\n"
}

# Check which helper is installed
check_helper() {
    for helper in "${!HELPERS[@]}"; do
        if command -v "$helper" &>/dev/null; then
            echo "$helper"
            return 0
        fi
    done
    echo ""
    return 1
}

# List available helpers
list_helpers() {
    log_section "Available AUR Helpers"
    
    for helper in "${!HELPERS[@]}"; do
        local installed=""
        if command -v "$helper" &>/dev/null; then
            installed="${GREEN}[Installed]${NC}"
        fi
        echo -e "  ${BOLD}$helper${NC} - ${HELPERS[$helper]} $installed"
    done
}

# Install AUR helper
install_helper() {
    local helper="$1"
    
    if [[ -z "$helper" ]]; then
        log_error "Please specify AUR helper name"
        return 1
    fi
    
    log_section "Installing $helper"
    
    # Check if already installed
    if command -v "$helper" &>/dev/null; then
        log_warn "$helper is already installed"
        return 0
    fi
    
    # Install dependencies
    sudo pacman -S --needed git base-devel
    
    # Clone and build
    local temp_dir="/tmp/rearch-aur-$$"
    mkdir -p "$temp_dir"
    cd "$temp_dir"
    
    git clone "https://aur.archlinux.org/$helper.git"
    cd "$helper"
    makepkg -si
    
    # Cleanup
    cd /
    rm -rf "$temp_dir"
    
    log_success "$helper installed"
}

# Remove AUR helper
remove_helper() {
    local helper="$1"
    
    if [[ -z "$helper" ]]; then
        log_error "Please specify AUR helper name"
        return 1
    fi
    
    log_section "Removing $helper"
    
    if command -v "$helper" &>/dev/null; then
        sudo pacman -Rns "$helper"
        log_success "$helper removed"
    else
        log_warn "$helper is not installed"
    fi
}

# Search AUR
search_aur() {
    local query="$1"
    
    if [[ -z "$query" ]]; then
        log_error "Please specify search query"
        return 1
    fi
    
    local helper=$(check_helper)
    
    if [[ -z "$helper" ]]; then
        log_error "No AUR helper installed. Install one first."
        return 1
    fi
    
    log_section "Search Results for '$query'"
    
    case "$helper" in
        yay) yay -Ss "$query" ;;
        paru) paru -Ss "$query" ;;
        trizen) trizen -Ss "$query" ;;
        pikaur) pikaur -Ss "$query" ;;
    esac
}

# Install AUR package
install_pkg() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    local helper=$(check_helper)
    
    if [[ -z "$helper" ]]; then
        log_error "No AUR helper installed. Install one first."
        return 1
    fi
    
    log_section "Installing $pkg"
    
    case "$helper" in
        yay) yay -S "$pkg" ;;
        paru) paru -S "$pkg" ;;
        trizen) trizen -S "$pkg" ;;
        pikaur) pikaur -S "$pkg" ;;
    esac
}

# Update AUR packages
update_aur() {
    local helper=$(check_helper)
    
    if [[ -z "$helper" ]]; then
        log_error "No AUR helper installed. Install one first."
        return 1
    fi
    
    log_section "Updating AUR Packages"
    
    case "$helper" in
        yay) yay -Sua ;;
        paru) paru -Sua ;;
        trizen) trizen -Sua ;;
        pikaur) pikaur -Sua ;;
    esac
}

# Show installed AUR packages
list_aur_pkgs() {
    log_section "Installed AUR Packages"
    
    local count=$(pacman -Qqm 2>/dev/null | wc -l)
    log_info "Total AUR packages: $count"
    
    echo ""
    pacman -Qqm 2>/dev/null | head -30
}

# Clean AUR cache
clean_aur() {
    log_section "Clean AUR Cache"
    
    local helper=$(check_helper)
    
    # Clean build cache
    rm -rf "$HOME/.cache/yay"/* 2>/dev/null || true
    rm -rf "$HOME/.cache/paru"/* 2>/dev/null || true
    
    # Clean with helper if available
    if [[ -n "$helper" ]]; then
        case "$helper" in
            yay) yay -Sc ;;
            paru) paru -Sc ;;
        esac
    fi
    
    log_success "AUR cache cleaned"
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        local current=$(check_helper)
        if [[ -n "$current" ]]; then
            echo -e "Current helper: ${GREEN}$current${NC}"
        else
            echo -e "Current helper: ${RED}None${NC}"
        fi
        echo ""
        
        echo "Options:"
        echo "1) List AUR helpers"
        echo "2) Install AUR helper"
        echo "3) Remove AUR helper"
        echo "4) Search AUR"
        echo "5) Install AUR package"
        echo "6) Update AUR packages"
        echo "7) List installed AUR packages"
        echo "8) Clean AUR cache"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) list_helpers; read -n1 -rp "Press any key..." ;;
            2)
                list_helpers
                read -rp "Helper to install: " helper
                install_helper "$helper"
                read -n1 -rp "Press any key..."
                ;;
            3)
                read -rp "Helper to remove: " helper
                remove_helper "$helper"
                read -n1 -rp "Press any key..."
                ;;
            4)
                read -rp "Search query: " query
                search_aur "$query"
                read -n1 -rp "Press any key..."
                ;;
            5)
                read -rp "Package name: " pkg
                install_pkg "$pkg"
                read -n1 -rp "Press any key..."
                ;;
            6) update_aur; read -n1 -rp "Press any key..." ;;
            7) list_aur_pkgs; read -n1 -rp "Press any key..." ;;
            8) clean_aur; read -n1 -rp "Press any key..." ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-aur [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  list              List available helpers"
    echo "  install HELPER    Install AUR helper"
    echo "  remove HELPER     Remove AUR helper"
    echo "  search QUERY      Search AUR"
    echo "  install-pkg PKG   Install AUR package"
    echo "  update            Update AUR packages"
    echo "  packages          List installed AUR packages"
    echo "  clean             Clean AUR cache"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        list) list_helpers ;;
        install) install_helper "$2" ;;
        remove) remove_helper "$2" ;;
        search) search_aur "$2" ;;
        install-pkg) install_pkg "$2" ;;
        update) update_aur ;;
        packages) list_aur_pkgs ;;
        clean) clean_aur ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
