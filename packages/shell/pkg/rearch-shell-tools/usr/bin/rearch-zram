#!/bin/bash
#
# rearch-zram - ZRAM manager for ReArch OS
# Configure and optimize ZRAM settings
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
ZRAM_CONF="/etc/systemd/zram-generator.conf"

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  _____      _
 |__  /___ _| |_
   / // _ \| __|
  / /| (_) | |_
 /____\___/ \__|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}ZRAM Manager for ReArch OS${NC}\n"
}

# Show ZRAM status
show_status() {
    log_section "ZRAM Status"
    
    if [[ -d /sys/block/zram0 ]]; then
        local disksize=$(cat /sys/block/zram0/disksize 2>/dev/null | numfmt --to=iec 2>/dev/null || echo "N/A")
        local compr_data=$(cat /sys/block/zram0/compr_data_size 2>/dev/null | numfmt --to=iec 2>/dev/null || echo "N/A")
        local orig_data=$(cat /sys/block/zram0/orig_data_size 2>/dev/null | numfmt --to=iec 2>/dev/null || echo "N/A")
        local mem_used=$(cat /sys/block/zram0/mem_used_total 2>/dev/null | numfmt --to=iec 2>/dev/null || echo "N/A")
        local algorithm=$(cat /sys/block/zram0/comp_algorithm 2>/dev/null | grep -oP '\[\K[^\]]+' | head -1 || echo "N/A")
        
        echo -e "${BOLD}Device:${NC}        /dev/zram0"
        echo -e "${BOLD}Disk Size:${NC}     $disksize"
        echo -e "${BOLD}Original Data:${NC} $orig_data"
        echo -e "${BOLD}Compressed:${NC}    $compr_data"
        echo -e "${BOLD}Memory Used:${NC}   $mem_used"
        echo -e "${BOLD}Algorithm:${NC}     $algorithm"
        
        # Calculate compression ratio
        if [[ -f /sys/block/zram0/compr_data_size && -f /sys/block/zram0/orig_data_size ]]; then
            local compr=$(cat /sys/block/zram0/compr_data_size)
            local orig=$(cat /sys/block/zram0/orig_data_size)
            if [[ $compr -gt 0 ]]; then
                local ratio=$(echo "scale=2; $orig / $compr" | bc 2>/dev/null || echo "N/A")
                echo -e "${BOLD}Ratio:${NC}         ${ratio}x"
            fi
        fi
    else
        log_warn "ZRAM is not enabled"
    fi
}

# Enable ZRAM
enable_zram() {
    log_section "Enable ZRAM"
    
    # Check if zram-generator is installed
    if ! systemctl cat systemd-zram-setup@zram0.service &>/dev/null; then
        log_info "Installing zram-generator..."
        sudo pacman -S zram-generator
    fi
    
    # Create config
    sudo mkdir -p /etc/systemd
    
    cat << 'EOF' | sudo tee "$ZRAM_CONF" > /dev/null
[zram0]
zram-size = ram / 2
compression-algorithm = zstd
EOF
    
    # Enable and start
    sudo systemctl daemon-reload
    sudo systemctl start systemd-zram-setup@zram0.service 2>/dev/null || true
    sudo systemctl enable systemd-zram-setup@zram0.service 2>/dev/null || true
    
    log_success "ZRAM enabled"
}

# Disable ZRAM
disable_zram() {
    log_section "Disable ZRAM"
    
    sudo systemctl stop systemd-zram-setup@zram0.service 2>/dev/null || true
    sudo systemctl disable systemd-zram-setup@zram0.service 2>/dev/null || true
    
    # Remove config
    if [[ -f "$ZRAM_CONF" ]]; then
        sudo rm "$ZRAM_CONF"
    fi
    
    log_success "ZRAM disabled"
}

# Configure ZRAM
configure_zram() {
    log_section "Configure ZRAM"
    
    echo "Select configuration:"
    echo "1) Conservative (RAM/4, lzo-rle)"
    echo "2) Balanced (RAM/2, zstd)"
    echo "3) Aggressive (RAM, lz4)"
    echo "4) Custom"
    
    read -rp "Choice: " choice
    
    case "$choice" in
        1)
            cat << 'EOF' | sudo tee "$ZRAM_CONF" > /dev/null
[zram0]
zram-size = ram / 4
compression-algorithm = lzo-rle
EOF
            ;;
        2)
            cat << 'EOF' | sudo tee "$ZRAM_CONF" > /dev/null
[zram0]
zram-size = ram / 2
compression-algorithm = zstd
EOF
            ;;
        3)
            cat << 'EOF' | sudo tee "$ZRAM_CONF" > /dev/null
[zram0]
zram-size = ram
compression-algorithm = lz4
EOF
            ;;
        4)
            read -rp "ZRAM size (e.g., ram/2, 4G): " size
            read -rp "Compression algorithm (zstd, lz4, lzo-rle): " algo
            
            cat << EOF | sudo tee "$ZRAM_CONF" > /dev/null
[zram0]
zram-size = $size
compression-algorithm = $algo
EOF
            ;;
        *)
            log_error "Invalid choice"
            return 1
            ;;
    esac
    
    # Reload
    sudo systemctl daemon-reload
    sudo systemctl restart systemd-zram-setup@zram0.service 2>/dev/null || true
    
    log_success "ZRAM configured"
}

# Show stats continuously
monitor_zram() {
    log_info "Monitoring ZRAM (Ctrl+C to exit)..."
    watch -n 1 'cat /proc/swaps | grep zram; echo "---"; cat /sys/block/zram0/mm_stat 2>/dev/null | tr " " "\n" | head -8'
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        show_status
        echo ""
        
        echo "Options:"
        echo "1) Enable ZRAM"
        echo "2) Disable ZRAM"
        echo "3) Configure ZRAM"
        echo "4) Monitor ZRAM"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) enable_zram; read -n1 -rp "Press any key..." ;;
            2) disable_zram; read -n1 -rp "Press any key..." ;;
            3) configure_zram; read -n1 -rp "Press any key..." ;;
            4) monitor_zram ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-zram [COMMAND]"
    echo ""
    echo "Commands:"
    echo "  status            Show ZRAM status"
    echo "  enable            Enable ZRAM"
    echo "  disable           Disable ZRAM"
    echo "  config            Configure ZRAM"
    echo "  monitor           Monitor ZRAM"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        status) show_status ;;
        enable) enable_zram ;;
        disable) disable_zram ;;
        config) configure_zram ;;
        monitor) monitor_zram ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
