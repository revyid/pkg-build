#!/bin/bash
#
# rearch-wifi - Simplified TUI for managing WiFi connections
# A user-friendly wrapper around NetworkManager and iwd
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
NMCLI="nmcli"
USE_IWD=false

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
 __      _____ _   _ ___  _____
 \ \    / /_ _| | | | _ \/ __/
  \ \/\/ / | || |_| |   /\__ \
   \_/\_/ |___|\___/|_|_\|___/
EOF
    echo -e "${NC}"
    echo -e "${BOLD}WiFi Manager for ReArch OS${NC}\n"
}

# Check if WiFi is available
check_wifi() {
    if ! command -v nmcli &>/dev/null; then
        log_error "NetworkManager not installed"
        exit 1
    fi
    
    # Check if WiFi is enabled
    local wifi_status=$(nmcli radio wifi 2>/dev/null)
    if [[ "$wifi_status" != "enabled" ]]; then
        log_warn "WiFi is disabled"
        return 1
    fi
    
    return 0
}

# Get WiFi device
get_wifi_device() {
    nmcli device show | grep "GENERAL.DEVICE" | grep -v "lo\|eth\|enp" | head -1 | awk '{print $2}'
}

# List available networks
list_networks() {
    local device=$(get_wifi_device)
    
    if [[ -z "$device" ]]; then
        log_error "No WiFi device found"
        return 1
    fi
    
    log_info "Scanning for networks..."
    nmcli device wifi rescan 2>/dev/null || true
    sleep 1
    
    echo ""
    echo -e "${BOLD}%-4s %-30s %-10s %-8s %-10s${NC}" "No." "SSID" "Signal" "Security" "Connected"
    echo "─────────────────────────────────────────────────────────────────────"
    
    local count=1
    nmcli -t -f SSID,SIGNAL,SECURITY,ACTIVE device wifi list 2>/dev/null | while IFS=: read -r ssid signal security active; do
        [[ -z "$ssid" ]] && continue
        
        local signal_bar=""
        if [[ $signal -ge 80 ]]; then
            signal_bar="${GREEN}▬▬▬▬▬${NC}"
        elif [[ $signal -ge 60 ]]; then
            signal_bar="${GREEN}▬▬▬▬${NC}${RED}▬${NC}"
        elif [[ $signal -ge 40 ]]; then
            signal_bar="${YELLOW}▬▬▬${NC}${RED}▬▬${NC}"
        elif [[ $signal -ge 20 ]]; then
            signal_bar="${YELLOW}▬▬${NC}${RED}▬▬▬${NC}"
        else
            signal_bar="${RED}▬${NC}${RED}▬▬▬▬${NC}"
        fi
        
        local security_short="${security:--}"
        [[ ${#security_short} -gt 8 ]] && security_short="${security_short:0:8}"
        
        local connected=""
        [[ "$active" == "yes" ]] && connected="${GREEN}●${NC}"
        
        printf "%-4s %-30s %-10b %-8s %-10b\n" "$count" "${ssid:0:30}" "$signal_bar" "$security_short" "$connected"
        ((count++))
    done
    
    echo ""
}

# Connect to network
connect_network() {
    local ssid="$1"
    local password="$2"
    
    log_info "Connecting to '$ssid'..."
    
    if [[ -n "$password" ]]; then
        nmcli device wifi connect "$ssid" password "$password" 2>&1 | grep -v "Error:" || {
            log_error "Failed to connect to '$ssid'"
            return 1
        }
    else
        nmcli device wifi connect "$ssid" 2>&1 | grep -v "Error:" || {
            log_error "Failed to connect to '$ssid'"
            return 1
        }
    fi
    
    log_success "Connected to '$ssid'"
}

# Disconnect from network
disconnect_network() {
    local device=$(get_wifi_device)
    
    log_info "Disconnecting..."
    nmcli device disconnect "$device" 2>/dev/null || {
        log_error "Failed to disconnect"
        return 1
    }
    
    log_success "Disconnected"
}

# Show connection status
show_status() {
    local device=$(get_wifi_device)
    
    echo ""
    echo -e "${CYAN}${BOLD}Connection Status${NC}"
    echo "─────────────────────────────────────"
    
    if [[ -z "$device" ]]; then
        echo "WiFi device: Not found"
        return
    fi
    
    local status=$(nmcli device show "$device" 2>/dev/null | grep "GENERAL.STATE" | awk -F': ' '{print $2}')
    local connection=$(nmcli connection show --active 2>/dev/null | grep -v "NAME" | head -1 | awk '{print $1}')
    local ip=$(nmcli device show "$device" 2>/dev/null | grep "IP4.ADDRESS" | head -1 | awk '{print $2}')
    local gateway=$(nmcli device show "$device" 2>/dev/null | grep "IP4.GATEWAY" | awk '{print $2}')
    local dns=$(nmcli device show "$device" 2>/dev/null | grep "IP4.DNS" | awk '{print $2}')
    
    echo -e "${BOLD}Device:${NC}     $device"
    echo -e "${BOLD}Status:${NC}     $status"
    echo -e "${BOLD}Network:${NC}    ${connection:-Not connected}"
    echo -e "${BOLD}IP Address:${NC} ${ip:-N/A}"
    echo -e "${BOLD}Gateway:${NC}    ${gateway:-N/A}"
    echo -e "${BOLD}DNS:${NC}        ${dns:-N/A}"
    echo ""
}

# Toggle WiFi
toggle_wifi() {
    local current=$(nmcli radio wifi 2>/dev/null)
    
    if [[ "$current" == "enabled" ]]; then
        nmcli radio wifi off
        log_info "WiFi disabled"
    else
        nmcli radio wifi on
        log_info "WiFi enabled"
    fi
}

# Forget network
forget_network() {
    local ssid="$1"
    
    log_info "Forgetting network '$ssid'..."
    nmcli connection delete "$ssid" 2>/dev/null || {
        log_error "Failed to forget '$ssid'"
        return 1
    }
    
    log_success "Network '$ssid' forgotten"
}

# List saved networks
list_saved() {
    echo ""
    echo -e "${CYAN}${BOLD}Saved Networks${NC}"
    echo "─────────────────────────────────────"
    
    nmcli -t -f NAME,TYPE connection show 2>/dev/null | grep "802-11-wireless" | while IFS=: read -r name type; do
        echo "  - $name"
    done
    
    echo ""
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        show_status
        
        echo "Options:"
        echo "1) Scan and connect to network"
        echo "2) Disconnect"
        echo "3) Toggle WiFi"
        echo "4) List saved networks"
        echo "5) Forget a network"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1)
                list_networks
                read -rp "Enter network number or SSID: " network
                
                # Check if input is a number
                if [[ "$network" =~ ^[0-9]+$ ]]; then
                    ssid=$(nmcli -t -f SSID device wifi list 2>/dev/null | sed -n "${network}p")
                else
                    ssid="$network"
                fi
                
                # Check if network is secured
                local security=$(nmcli -t -f SSID,SECURITY device wifi list 2>/dev/null | grep "^${ssid}:" | cut -d: -f2)
                
                local password=""
                if [[ -n "$security" ]] && [[ "$security" != "--" ]]; then
                    read -rsp "Enter password: " password
                    echo ""
                fi
                
                connect_network "$ssid" "$password"
                read -n1 -rp "Press any key to continue..."
                ;;
            2)
                disconnect_network
                read -n1 -rp "Press any key to continue..."
                ;;
            3)
                toggle_wifi
                read -n1 -rp "Press any key to continue..."
                ;;
            4)
                list_saved
                read -n1 -rp "Press any key to continue..."
                ;;
            5)
                list_saved
                read -rp "Enter network name to forget: " ssid
                forget_network "$ssid"
                read -n1 -rp "Press any key to continue..."
                ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-wifi [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  scan              Scan for networks"
    echo "  connect SSID      Connect to a network"
    echo "  disconnect        Disconnect from current network"
    echo "  status            Show connection status"
    echo "  toggle            Toggle WiFi on/off"
    echo "  list              List saved networks"
    echo "  forget SSID       Forget a saved network"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        scan)
            list_networks
            ;;
        connect)
            if [[ -z "$2" ]]; then
                log_error "Please specify SSID"
                exit 1
            fi
            connect_network "$2" "$3"
            ;;
        disconnect)
            disconnect_network
            ;;
        status)
            show_status
            ;;
        toggle)
            toggle_wifi
            ;;
        list)
            list_saved
            ;;
        forget)
            if [[ -z "$2" ]]; then
                log_error "Please specify SSID"
                exit 1
            fi
            forget_network "$2"
            ;;
        interactive)
            interactive_menu
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            log_error "Unknown command: $1"
            usage
            exit 1
            ;;
    esac
}

main "$@"
