#!/bin/bash
#
# rearch-ports - Network port manager for ReArch OS
# Monitor, scan, and manage network ports and connections
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  ___            _         ___           _
 | _ \___ _ _ __| |___ _ _| _ \___ _ __ | |__ _ _ ___
 |  _/ -_) '_/ _` / -_) '_|  _/ -_) '  \| / _` |_ / -_)
 |_| \___|_| \__,_\___|_| |_| \___|_|_|_|_\__,_/__\___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Port Manager for ReArch OS${NC}\n"
}

# List listening ports
list_listening() {
    log_section "Listening Ports"
    
    echo -e "${BOLD}PROTO  | PORT   | PROCESS${NC}"
    echo "───────|────────|─────────────────────────────"
    
    ss -tlnp 2>/dev/null | grep LISTEN | while read -r line; do
        local proto=$(echo "$line" | awk '{print $1}')
        local local_addr=$(echo "$line" | awk '{print $4}')
        local port=$(echo "$local_addr" | grep -oE '[0-9]+$')
        local process=$(echo "$line" | grep -oP 'users:\(\("\K[^"]+' | head -1)
        
        printf "%-6s | %-6s | %s\n" "$proto" "$port" "${process:--}"
    done | sort -t'|' -k2 -n | uniq
}

# List established connections
list_connections() {
    log_section "Established Connections"
    
    echo -e "${BOLD}PROTO  | LOCAL           | REMOTE          | STATE${NC}"
    echo "───────|─────────────────|─────────────────|─────────────"
    
    ss -tnp state established 2>/dev/null | tail -n +2 | while read -r line; do
        local proto=$(echo "$line" | awk '{print $1}')
        local local_addr=$(echo "$line" | awk '{print $4}')
        local remote_addr=$(echo "$line" | awk '{print $5}')
        local state=$(echo "$line" | awk '{print $2}')
        
        printf "%-6s | %-15s | %-15s | %s\n" "$proto" "$local_addr" "$remote_addr" "$state"
    done | head -20
}

# Check if port is in use
port_in_use() {
    local port="$1"
    
    if [[ -z "$port" ]]; then
        log_error "Please specify port number"
        return 1
    fi
    
    log_section "Port $port Status"
    
    local result=$(ss -tlnp 2>/dev/null | grep ":$port ")
    
    if [[ -n "$result" ]]; then
        log_warn "Port $port is in use"
        echo "$result"
    else
        log_success "Port $port is available"
    fi
}

# Scan common ports on localhost
scan_local() {
    log_section "Local Port Scan"
    
    local common_ports=(22 80 443 3306 5432 6379 8080 8443 3000 5000)
    
    echo -e "${BOLD}PORT  | STATUS${NC}"
    echo "──────|─────────"
    
    for port in "${common_ports[@]}"; do
        if timeout 1 bash -c "echo >/dev/tcp/localhost/$port" 2>/dev/null; then
            printf "%-5s | ${GREEN}OPEN${NC}\n" "$port"
        else
            printf "%-5s | ${RED}CLOSED${NC}\n" "$port"
        fi
    done
}

# Kill process using port
kill_port() {
    local port="$1"
    
    if [[ -z "$port" ]]; then
        log_error "Please specify port number"
        return 1
    fi
    
    log_section "Killing Process on Port $port"
    
    # Find PID using the port
    local pid=$(ss -tlnp 2>/dev/null | grep ":$port " | grep -oP 'pid=\K[0-9]+' | head -1)
    
    if [[ -z "$pid" ]]; then
        log_warn "No process found using port $port"
        return 1
    fi
    
    local process=$(ps -p "$pid" -o comm= 2>/dev/null)
    
    log_warn "Found process: $process (PID: $pid)"
    read -rp "Kill this process? [y/N]: " confirm
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        kill -9 "$pid" 2>/dev/null && log_success "Process killed" || log_error "Failed to kill process"
    else
        log_info "Cancelled"
    fi
}

# Show network statistics
show_stats() {
    log_section "Network Statistics"
    
    echo -e "${BOLD}Interface Statistics:${NC}"
    cat /proc/net/dev | tail -n +3 | while read -r line; do
        local iface=$(echo "$line" | awk '{print $1}' | tr -d ':')
        local rx_bytes=$(echo "$line" | awk '{print $2}')
        local tx_bytes=$(echo "$line" | awk '{print $10}')
        
        if [[ "$iface" != "lo" ]]; then
            local rx_human=$(echo "scale=2; $rx_bytes/1024/1024" | bc 2>/dev/null || echo "N/A")
            local tx_human=$(echo "scale=2; $tx_bytes/1024/1024" | bc 2>/dev/null || echo "N/A")
            echo "  $iface: RX ${rx_human} MB, TX ${tx_human} MB"
        fi
    done
    
    echo ""
    echo -e "${BOLD}Connection Statistics:${NC}"
    ss -s 2>/dev/null || echo "  Unable to get statistics"
}

# Monitor connections in real-time
monitor_connections() {
    log_info "Monitoring connections (Ctrl+C to exit)..."
    echo ""
    
    watch -n 1 'ss -tnp state established | tail -n +2 | wc -l; echo "---"; ss -tnp state established | head -10'
}

# Check firewall rules
firewall_status() {
    log_section "Firewall Status"
    
    if command -v firewall-cmd &>/dev/null; then
        echo -e "${BOLD}Firewalld:${NC}"
        firewall-cmd --state 2>/dev/null && {
            echo ""
            echo -e "${BOLD}Active Zones:${NC}"
            firewall-cmd --get-active-zones 2>/dev/null
            echo ""
            echo -e "${BOLD}Open Ports:${NC}"
            firewall-cmd --list-ports 2>/dev/null
        } || echo "  Firewalld is not running"
    elif command -v ufw &>/dev/null; then
        echo -e "${BOLD}UFW:${NC}"
        ufw status verbose 2>/dev/null
    else
        log_warn "No firewall detected"
    fi
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        echo "Options:"
        echo "1) List listening ports"
        echo "2) List established connections"
        echo "3) Check port status"
        echo "4) Scan local ports"
        echo "5) Kill process on port"
        echo "6) Show network statistics"
        echo "7) Monitor connections"
        echo "8) Firewall status"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) list_listening; read -n1 -rp "Press any key..." ;;
            2) list_connections; read -n1 -rp "Press any key..." ;;
            3)
                read -rp "Port number: " port
                port_in_use "$port"
                read -n1 -rp "Press any key..."
                ;;
            4) scan_local; read -n1 -rp "Press any key..." ;;
            5)
                read -rp "Port number: " port
                kill_port "$port"
                read -n1 -rp "Press any key..."
                ;;
            6) show_stats; read -n1 -rp "Press any key..." ;;
            7) monitor_connections ;;
            8) firewall_status; read -n1 -rp "Press any key..." ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-ports [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  list              List listening ports"
    echo "  connections       List established connections"
    echo "  check PORT        Check if port is in use"
    echo "  scan              Scan common local ports"
    echo "  kill PORT         Kill process using port"
    echo "  stats             Show network statistics"
    echo "  monitor           Monitor connections"
    echo "  firewall          Show firewall status"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        list) list_listening ;;
        connections) list_connections ;;
        check) port_in_use "$2" ;;
        scan) scan_local ;;
        kill) kill_port "$2" ;;
        stats) show_stats ;;
        monitor) monitor_connections ;;
        firewall) firewall_status ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
