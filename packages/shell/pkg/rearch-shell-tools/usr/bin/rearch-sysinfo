#!/bin/bash
#
# rearch-sysinfo - Detailed system information for ReArch OS
# Hardware, software, and performance information
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  ___ _   _ ___  ___   ___ _   _ ___
 / __| | | | _ \/ __| / __| | | |_ _|
 \__ \ |_| |   /\__ \ \__ \ |_| || |
 |___/\___/|_|_\|___/ |___/\___/|___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}System Information for ReArch OS${NC}\n"
}

# OS Information
show_os() {
    log_section "Operating System"
    
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        echo -e "${BOLD}Name:${NC}        ${PRETTY_NAME:-$NAME}"
        echo -e "${BOLD}Version:${NC}     ${VERSION_ID:-Rolling}"
        echo -e "${BOLD}Codename:${NC}    ${BUILD_ID:-$VERSION_CODENAME}"
        echo -e "${BOLD}ID:${NC}          $ID"
    fi
    
    echo -e "${BOLD}Kernel:${NC}      $(uname -r)"
    echo -e "${BOLD}Architecture:${NC} $(uname -m)"
    echo -e "${BOLD}Hostname:${NC}    $(hostname)"
    echo -e "${BOLD}Uptime:${NC}      $(uptime -p 2>/dev/null || uptime | awk -F',' '{print $1}')"
}

# CPU Information
show_cpu() {
    log_section "CPU Information"
    
    local cpu_model=$(grep -m1 'model name' /proc/cpuinfo | cut -d: -f2 | sed 's/^ *//')
    local cpu_cores=$(nproc)
    local cpu_threads=$(grep -c '^processor' /proc/cpuinfo)
    
    echo -e "${BOLD}Model:${NC}       $cpu_model"
    echo -e "${BOLD}Cores:${NC}       $cpu_cores"
    echo -e "${BOLD}Threads:${NC}     $cpu_threads"
    
    if [[ -f /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq ]]; then
        local max_freq=$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 2>/dev/null)
        echo -e "${BOLD}Max Freq:${NC}    $((max_freq / 1000)) MHz"
    fi
    
    if [[ -f /sys/class/thermal/thermal_zone0/temp ]]; then
        local temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
        echo -e "${BOLD}Temp:${NC}        $((temp / 1000))°C"
    fi
}

# Memory Information
show_memory() {
    log_section "Memory Information"
    
    local mem_info=$(free -h | grep "^Mem:")
    local total=$(echo "$mem_info" | awk '{print $2}')
    local used=$(echo "$mem_info" | awk '{print $3}')
    local free=$(echo "$mem_info" | awk '{print $4}')
    local shared=$(echo "$mem_info" | awk '{print $5}')
    local buff_cache=$(echo "$mem_info" | awk '{print $6}')
    local available=$(echo "$mem_info" | awk '{print $7}')
    
    echo -e "${BOLD}Total:${NC}       $total"
    echo -e "${BOLD}Used:${NC}        $used"
    echo -e "${BOLD}Free:${NC}        $free"
    echo -e "${BOLD}Shared:${NC}      $shared"
    echo -e "${BOLD}Buff/Cache:${NC}  $buff_cache"
    echo -e "${BOLD}Available:${NC}   $available"
    
    # Swap
    local swap_info=$(free -h | grep "^Swap:")
    if [[ -n "$swap_info" ]]; then
        local swap_total=$(echo "$swap_info" | awk '{print $2}')
        local swap_used=$(echo "$swap_info" | awk '{print $3}')
        echo ""
        echo -e "${BOLD}Swap Total:${NC}  $swap_total"
        echo -e "${BOLD}Swap Used:${NC}   $swap_used"
    fi
}

# Disk Information
show_disk() {
    log_section "Disk Information"
    
    echo -e "${BOLD}Filesystem      Size  Used  Avail  Use%  Mounted on${NC}"
    df -h 2>/dev/null | grep -v "tmpfs\|devtmpfs\|loop" | tail -n +2 | while read -r line; do
        echo "  $line"
    done
    
    # Disk models
    echo ""
    echo -e "${BOLD}Disks:${NC}"
    lsblk -d -o NAME,SIZE,MODEL,TYPE 2>/dev/null | grep disk | while read -r line; do
        echo "  $line"
    done
}

# GPU Information
show_gpu() {
    log_section "GPU Information"
    
    local gpu_info=$(lspci 2>/dev/null | grep -i vga | head -1)
    if [[ -n "$gpu_info" ]]; then
        echo -e "${BOLD}GPU:${NC}         $(echo "$gpu_info" | cut -d: -f3 | sed 's/^ *//')"
        
        # Driver info
        local gpu_driver=$(lspci -k 2>/dev/null | grep -A2 -i vga | grep "Kernel driver" | awk '{print $3}')
        if [[ -n "$gpu_driver" ]]; then
            echo -e "${BOLD}Driver:${NC}      $gpu_driver"
        fi
    fi
    
    # NVIDIA info
    if command -v nvidia-smi &>/dev/null; then
        echo ""
        nvidia-smi --query-gpu=name,driver_version,memory.total,temperature.gpu --format=csv,noheader 2>/dev/null | while IFS=, read -r name driver mem temp; do
            echo -e "${BOLD}NVIDIA GPU:${NC}  $name"
            echo -e "${BOLD}Driver:${NC}      $driver"
            echo -e "${BOLD}Memory:${NC}      $mem"
            echo -e "${BOLD}Temp:${NC}        $temp"
        done
    fi
}

# Network Information
show_network() {
    log_section "Network Information"
    
    # Interfaces
    echo -e "${BOLD}Interfaces:${NC}"
    ip -br addr 2>/dev/null | grep -v "^lo" | while read -r line; do
        echo "  $line"
    done
    
    # Gateway
    echo ""
    echo -e "${BOLD}Gateway:${NC}     $(ip route 2>/dev/null | grep default | awk '{print $3}' | head -1)"
    
    # DNS
    echo -e "${BOLD}DNS:${NC}         $(grep nameserver /etc/resolv.conf 2>/dev/null | awk '{print $2}' | head -1)"
    
    # Public IP
    echo -e "${BOLD}Public IP:${NC}   $(curl -s --max-time 5 https://ipinfo.io/ip 2>/dev/null || echo "N/A")"
}

# Battery Information
show_battery() {
    if [[ -d /sys/class/power_supply/BAT0 ]]; then
        log_section "Battery Information"
        
        local capacity=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
        local status=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)
        local health=$(cat /sys/class/power_supply/BAT0/health 2>/dev/null || echo "Unknown")
        
        echo -e "${BOLD}Capacity:${NC}    ${capacity}%"
        echo -e "${BOLD}Status:${NC}      $status"
        echo -e "${BOLD}Health:${NC}      $health"
    fi
}

# Package Statistics
show_packages() {
    log_section "Package Statistics"
    
    local pacman_count=$(pacman -Qq 2>/dev/null | wc -l)
    local explicit=$(pacman -Qqe 2>/dev/null | wc -l)
    local aur=$(pacman -Qqm 2>/dev/null | wc -l)
    
    echo -e "${BOLD}Total:${NC}       $pacman_count"
    echo -e "${BOLD}Explicit:${NC}    $explicit"
    echo -e "${BOLD}AUR:${NC}         $aur"
    
    if command -v flatpak &>/dev/null; then
        local flatpak_count=$(flatpak list 2>/dev/null | wc -l)
        echo -e "${BOLD}Flatpak:${NC}     $flatpak_count"
    fi
}

# Show all
show_all() {
    show_os
    show_cpu
    show_memory
    show_disk
    show_gpu
    show_network
    show_battery
    show_packages
}

# Export to file
export_info() {
    local file="${1:-sysinfo.txt}"
    
    log_info "Exporting system information to $file..."
    
    {
        echo "ReArch OS System Information"
        echo "Generated: $(date)"
        echo "========================================"
        echo ""
        show_all
    } > "$file"
    
    log_success "System information exported to $file"
}

# Usage
usage() {
    echo "Usage: rearch-sysinfo [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  all               Show all information"
    echo "  os                Show OS information"
    echo "  cpu               Show CPU information"
    echo "  memory            Show memory information"
    echo "  disk              Show disk information"
    echo "  gpu               Show GPU information"
    echo "  network           Show network information"
    echo "  battery           Show battery information"
    echo "  packages          Show package statistics"
    echo "  export [FILE]     Export to file"
    echo "  --help, -h        Show this help message"
}

# Main
main() {
    show_banner
    
    case "${1:-all}" in
        all) show_all ;;
        os) show_os ;;
        cpu) show_cpu ;;
        memory) show_memory ;;
        disk) show_disk ;;
        gpu) show_gpu ;;
        network) show_network ;;
        battery) show_battery ;;
        packages) show_packages ;;
        export) export_info "$2" ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
