#!/bin/bash
#
# rearch-sync - Universal package sync tool for ReArch OS
# Handles pacman, AUR, and Flatpak updates in one command
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
UPDATE_PACMAN=true
UPDATE_AUR=true
UPDATE_FLATPAK=true
UPDATE_REARCH=true
DRY_RUN=false
NO_CONFIRM=false
CHECK_ONLY=false

# Statistics
PACMAN_UPDATES=0
AUR_UPDATES=0
FLATPAK_UPDATES=0
REARCH_UPDATES=0

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  ___ _   _ ___  ___   ___ _   _ ___
 / __| | | | _ \/ __| / __| | | |_ _|
 \__ \ |_| |   /\__ \ \__ \ |_| || |
 |___/\___/|_|_\|___/ |___/\___/|___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Universal Package Sync for ReArch OS${NC}\n"
}

# Check for updates - Pacman
check_pacman() {
    log_section "Checking Pacman Updates"
    
    # Update database
    if [[ "$DRY_RUN" == false ]]; then
        sudo pacman -Sy >/dev/null 2>&1
    fi
    
    # Check for updates
    local updates=$(pacman -Qu 2>/dev/null | grep -v "^\[" || true)
    PACMAN_UPDATES=$(echo "$updates" | grep -c "^" || echo 0)
    
    if [[ $PACMAN_UPDATES -gt 0 ]]; then
        log_info "Found $PACMAN_UPDATES Pacman update(s)"
        if [[ "$CHECK_ONLY" == true ]] || [[ "$VERBOSE" == true ]]; then
            echo "$updates" | head -20
            [[ $PACMAN_UPDATES -gt 20 ]] && log_info "... and $((PACMAN_UPDATES - 20)) more"
        fi
    else
        log_success "Pacman is up to date"
    fi
}

# Check for updates - AUR
check_aur() {
    log_section "Checking AUR Updates"
    
    local aur_helper=""
    
    # Detect AUR helper
    if command -v yay &>/dev/null; then
        aur_helper="yay"
    elif command -v paru &>/dev/null; then
        aur_helper="paru"
    elif command -v trizen &>/dev/null; then
        aur_helper="trizen"
    elif command -v pikaur &>/dev/null; then
        aur_helper="pikaur"
    fi
    
    if [[ -z "$aur_helper" ]]; then
        log_warn "No AUR helper found (install yay, paru, trizen, or pikaur)"
        UPDATE_AUR=false
        return
    fi
    
    log_info "Using AUR helper: $aur_helper"
    
    # Check for updates
    local updates
    case "$aur_helper" in
        yay) updates=$(yay -Qua 2>/dev/null || true) ;;
        paru) updates=$(paru -Qua 2>/dev/null || true) ;;
        trizen) updates=$(trizen -Qua 2>/dev/null || true) ;;
        pikaur) updates=$(pikaur -Qua 2>/dev/null || true) ;;
    esac
    
    AUR_UPDATES=$(echo "$updates" | grep -c "^" || echo 0)
    
    if [[ $AUR_UPDATES -gt 0 ]]; then
        log_info "Found $AUR_UPDATES AUR update(s)"
        if [[ "$CHECK_ONLY" == true ]] || [[ "$VERBOSE" == true ]]; then
            echo "$updates" | head -20
            [[ $AUR_UPDATES -gt 20 ]] && log_info "... and $((AUR_UPDATES - 20)) more"
        fi
    else
        log_success "AUR is up to date"
    fi
}

# Check for updates - Flatpak
check_flatpak() {
    log_section "Checking Flatpak Updates"
    
    if ! command -v flatpak &>/dev/null; then
        log_warn "Flatpak not installed"
        UPDATE_FLATPAK=false
        return
    fi
    
    # Check for updates
    local updates=$(flatpak remote-ls --updates 2>/dev/null || true)
    FLATPAK_UPDATES=$(echo "$updates" | grep -c "^" || echo 0)
    
    if [[ $FLATPAK_UPDATES -gt 0 ]]; then
        log_info "Found $FLATPAK_UPDATES Flatpak update(s)"
        if [[ "$CHECK_ONLY" == true ]] || [[ "$VERBOSE" == true ]]; then
            echo "$updates" | head -20
            [[ $FLATPAK_UPDATES -gt 20 ]] && log_info "... and $((FLATPAK_UPDATES - 20)) more"
        fi
    else
        log_success "Flatpak is up to date"
    fi
}

# Check for updates - ReArch repo
check_rearch() {
    log_section "Checking ReArch Repository Updates"
    
    # Check if rearch repo is configured
    if ! grep -q "^\[rearch\]" /etc/pacman.conf 2>/dev/null; then
        log_warn "ReArch repository not configured"
        UPDATE_REARCH=false
        return
    fi
    
    # Check for rearch-specific updates
    local updates=$(pacman -Qu 2>/dev/null | grep "^rearch" || true)
    REARCH_UPDATES=$(echo "$updates" | grep -c "^" || echo 0)
    
    if [[ $REARCH_UPDATES -gt 0 ]]; then
        log_info "Found $REARCH_UPDATES ReArch package update(s)"
        if [[ "$CHECK_ONLY" == true ]] || [[ "$VERBOSE" == true ]]; then
            echo "$updates"
        fi
    else
        log_success "ReArch packages are up to date"
    fi
}

# Update Pacman
update_pacman() {
    log_section "Updating Pacman Packages"
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would update Pacman packages"
        return
    fi
    
    local confirm_flag=""
    [[ "$NO_CONFIRM" == true ]] && confirm_flag="--noconfirm"
    
    sudo pacman -Syu $confirm_flag
    
    log_success "Pacman update complete"
}

# Update AUR
update_aur() {
    log_section "Updating AUR Packages"
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would update AUR packages"
        return
    fi
    
    local aur_helper=""
    command -v yay &>/dev/null && aur_helper="yay"
    command -v paru &>/dev/null && aur_helper="paru"
    command -v trizen &>/dev/null && aur_helper="trizen"
    command -v pikaur &>/dev/null && aur_helper="pikaur"
    
    [[ -z "$aur_helper" ]] && return
    
    local confirm_flag=""
    [[ "$NO_CONFIRM" == true ]] && confirm_flag="--noconfirm"
    
    case "$aur_helper" in
        yay) yay -Sua $confirm_flag ;;
        paru) paru -Sua $confirm_flag ;;
        trizen) trizen -Sua $confirm_flag ;;
        pikaur) pikaur -Sua $confirm_flag ;;
    esac
    
    log_success "AUR update complete"
}

# Update Flatpak
update_flatpak() {
    log_section "Updating Flatpak Packages"
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would update Flatpak packages"
        return
    fi
    
    local confirm_flag=""
    [[ "$NO_CONFIRM" == true ]] && confirm_flag="-y"
    
    flatpak update $confirm_flag
    
    # Also update unused runtimes
    flatpak uninstall --unused $confirm_flag 2>/dev/null || true
    
    log_success "Flatpak update complete"
}

# Show summary
show_summary() {
    local total=$((PACMAN_UPDATES + AUR_UPDATES + FLATPAK_UPDATES + REARCH_UPDATES))
    
    echo ""
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${CYAN}${BOLD}  Update Summary${NC}"
    echo -e "${CYAN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${BOLD}Pacman:${NC}  $PACMAN_UPDATES update(s) available"
    echo -e "  ${BOLD}AUR:${NC}     $AUR_UPDATES update(s) available"
    echo -e "  ${BOLD}Flatpak:${NC} $FLATPAK_UPDATES update(s) available"
    echo -e "  ${BOLD}ReArch:${NC}  $REARCH_UPDATES update(s) available"
    echo ""
    echo -e "  ${BOLD}Total:${NC}   $total update(s) available"
    echo ""
}

# Post-update cleanup
post_update_cleanup() {
    log_section "Post-Update Cleanup"
    
    # Clean pacman cache (keep last 3 versions)
    if command -v paccache &>/dev/null; then
        sudo paccache -rk3 2>/dev/null || true
    fi
    
    # Remove orphaned packages
    local orphans=$(pacman -Qdtq 2>/dev/null || true)
    if [[ -n "$orphans" ]]; then
        log_info "Found orphaned packages:"
        echo "$orphans"
        if [[ "$NO_CONFIRM" == true ]]; then
            echo "$orphans" | sudo pacman -Rns - 2>/dev/null || true
        else
            read -rp "Remove orphaned packages? [y/N]: " confirm
            [[ "$confirm" =~ ^[Yy]$ ]] && echo "$orphans" | sudo pacman -Rns - 2>/dev/null || true
        fi
    fi
    
    log_success "Cleanup complete"
}

# Usage
usage() {
    echo "Usage: rearch-sync [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --check, -c        Check for updates only (don't install)"
    echo "  --pacman-only      Update only Pacman packages"
    echo "  --aur-only         Update only AUR packages"
    echo "  --flatpak-only     Update only Flatpak packages"
    echo "  --no-confirm       Don't ask for confirmation"
    echo "  --dry-run          Show what would be updated"
    echo "  --verbose          Show detailed output"
    echo "  --help, -h         Show this help message"
    echo ""
    echo "Examples:"
    echo "  rearch-sync              # Full system update"
    echo "  rearch-sync --check      # Check for updates only"
    echo "  rearch-sync --no-confirm # Update without asking"
}

# Main
main() {
    VERBOSE=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check|-c) CHECK_ONLY=true ;;
            --pacman-only) UPDATE_AUR=false; UPDATE_FLATPAK=false; UPDATE_REARCH=false ;;
            --aur-only) UPDATE_PACMAN=false; UPDATE_FLATPAK=false; UPDATE_REARCH=false ;;
            --flatpak-only) UPDATE_PACMAN=false; UPDATE_AUR=false; UPDATE_REARCH=false ;;
            --no-confirm) NO_CONFIRM=true ;;
            --dry-run) DRY_RUN=true ;;
            --verbose) VERBOSE=true ;;
            --help|-h) usage; exit 0 ;;
            *) log_error "Unknown option: $1"; usage; exit 1 ;;
        esac
        shift
    done
    
    show_banner
    
    # Check phase
    if [[ "$UPDATE_PACMAN" == true ]]; then
        check_pacman
    fi
    
    if [[ "$UPDATE_AUR" == true ]]; then
        check_aur
    fi
    
    if [[ "$UPDATE_FLATPAK" == true ]]; then
        check_flatpak
    fi
    
    if [[ "$UPDATE_REARCH" == true ]]; then
        check_rearch
    fi
    
    show_summary
    
    # Exit if check-only
    if [[ "$CHECK_ONLY" == true ]]; then
        exit 0
    fi
    
    # No updates available
    local total=$((PACMAN_UPDATES + AUR_UPDATES + FLATPAK_UPDATES + REARCH_UPDATES))
    if [[ $total -eq 0 ]]; then
        log_success "Your system is up to date!"
        exit 0
    fi
    
    # Confirm update
    if [[ "$NO_CONFIRM" == false ]]; then
        echo ""
        read -rp "Proceed with update? [Y/n]: " confirm
        if [[ "$confirm" =~ ^[Nn]$ ]]; then
            log_info "Update cancelled"
            exit 0
        fi
    fi
    
    # Update phase
    if [[ "$UPDATE_PACMAN" == true ]] && [[ $PACMAN_UPDATES -gt 0 ]]; then
        update_pacman
    fi
    
    if [[ "$UPDATE_AUR" == true ]] && [[ $AUR_UPDATES -gt 0 ]]; then
        update_aur
    fi
    
    if [[ "$UPDATE_FLATPAK" == true ]] && [[ $FLATPAK_UPDATES -gt 0 ]]; then
        update_flatpak
    fi
    
    # Cleanup
    post_update_cleanup
    
    echo ""
    log_success "All updates complete!"
}

main "$@"
