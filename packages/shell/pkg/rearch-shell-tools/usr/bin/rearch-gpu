#!/bin/bash
#
# rearch-gpu - GPU management tool for ReArch OS
# Manage NVIDIA/AMD/Intel GPUs, drivers, and settings
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
   ___ ___ _   _
  / __| _ \ | | |
 | (_ |  _/ |_| |
  \___|_|  \___/
EOF
    echo -e "${NC}"
    echo -e "${BOLD}GPU Manager for ReArch OS${NC}\n"
}

# Detect GPU
detect_gpu() {
    local gpu_info=$(lspci 2>/dev/null | grep -i vga | head -1)
    
    if echo "$gpu_info" | grep -qi nvidia; then
        echo "nvidia"
    elif echo "$gpu_info" | grep -qi amd\|ati\|radeon; then
        echo "amd"
    elif echo "$gpu_info" | grep -qi intel; then
        echo "intel"
    else
        echo "unknown"
    fi
}

# Show GPU info
show_info() {
    log_section "GPU Information"
    
    local gpu_type=$(detect_gpu)
    local gpu_name=$(lspci 2>/dev/null | grep -i vga | head -1 | cut -d: -f3 | sed 's/^ *//')
    
    echo -e "${BOLD}GPU:${NC} $gpu_name"
    echo -e "${BOLD}Type:${NC} $gpu_type"
    echo ""
    
    case "$gpu_type" in
        nvidia)
            show_nvidia_info
            ;;
        amd)
            show_amd_info
            ;;
        intel)
            show_intel_info
            ;;
    esac
}

# Show NVIDIA info
show_nvidia_info() {
    if command -v nvidia-smi &>/dev/null; then
        echo -e "${BOLD}NVIDIA Driver Info:${NC}"
        nvidia-smi --query-gpu=name,driver_version,memory.total,memory.used,temperature.gpu,utilization.gpu --format=csv,noheader 2>/dev/null | while IFS=, read -r name driver mem_total mem_used temp util; do
            echo "  Name:       $name"
            echo "  Driver:     $driver"
            echo "  Memory:     $mem_used / $mem_total"
            echo "  Temp:       $temp"
            echo "  Util:       $util"
        done
        
        echo ""
        echo -e "${BOLD}NVIDIA Processes:${NC}"
        nvidia-smi pmon -s um -c 1 2>/dev/null | head -10 || echo "  No GPU processes"
    else
        log_warn "NVIDIA drivers not installed"
        echo ""
        echo "To install NVIDIA drivers:"
        echo "  sudo pacman -S nvidia nvidia-utils"
    fi
}

# Show AMD info
show_amd_info() {
    echo -e "${BOLD}AMD GPU Info:${NC}"
    
    # Try to get info from /sys
    for card in /sys/class/drm/card[0-9]/device; do
        [[ -d "$card" ]] || continue
        
        if [[ -f "$card/product_name" ]]; then
            echo "  Name:       $(cat $card/product_name 2>/dev/null)"
        fi
        
        if [[ -f "$card/pp_dpm_sclk" ]]; then
            echo "  Core Clock: $(cat $card/pp_dpm_sclk 2>/dev/null | grep '*' | awk '{print $2}')"
        fi
        
        if [[ -f "$card/gpu_metrics" ]]; then
            local temp=$(cat $card/gpu_metrics 2>/dev/null | head -c 2 | xxd -p)
            echo "  Temp:       $temp°C"
        fi
        
        if [[ -f "$card/mem_info_vram_total" ]]; then
            local mem_total=$(cat $card/mem_info_vram_total 2>/dev/null)
            local mem_used=$(cat $card/mem_info_vram_used 2>/dev/null)
            echo "  VRAM:       $(($mem_used / 1024 / 1024))MB / $(($mem_total / 1024 / 1024))MB"
        fi
    done
    
    if command -v radeontop &>/dev/null; then
        echo ""
        echo "Run 'radeontop' for real-time monitoring"
    fi
}

# Show Intel info
show_intel_info() {
    echo -e "${BOLD}Intel GPU Info:${NC}"
    
    if [[ -d /sys/class/drm/card0/device ]]; then
        local card="/sys/class/drm/card0/device"
        
        if [[ -f "$card/vendor" ]]; then
            local vendor=$(cat "$card/vendor" 2>/dev/null)
            echo "  Vendor ID:  $vendor"
        fi
        
        if [[ -f "$card/pp_dpm_sclk" ]]; then
            echo "  Core Clock: $(cat $card/pp_dpm_sclk 2>/dev/null | grep '*' | awk '{print $2}')"
        fi
        
        if [[ -f "$card/gpu_busy_percent" ]]; then
            echo "  GPU Usage:  $(cat $card/gpu_busy_percent 2>/dev/null)%"
        fi
    fi
    
    if command -v intel_gpu_top &>/dev/null; then
        echo ""
        echo "Run 'sudo intel_gpu_top' for real-time monitoring"
    fi
}

# Install NVIDIA drivers
install_nvidia() {
    log_section "Installing NVIDIA Drivers"
    
    log_info "This will install NVIDIA proprietary drivers"
    read -rp "Continue? [y/N]: " confirm
    
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        sudo pacman -S nvidia nvidia-utils nvidia-settings
        
        log_success "NVIDIA drivers installed"
        log_warn "Please reboot to complete installation"
    fi
}

# Install AMD drivers
install_amd() {
    log_section "Installing AMD Drivers"
    
    log_info "Installing AMD open-source drivers (mesa)..."
    sudo pacman -S mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon
    
    log_success "AMD drivers installed"
}

# Install Intel drivers
install_intel() {
    log_section "Installing Intel Drivers"
    
    log_info "Installing Intel drivers..."
    sudo pacman -S mesa lib32-mesa vulkan-intel lib32-vulkan-intel
    
    log_success "Intel drivers installed"
}

# Switch GPU (for hybrid graphics)
switch_gpu() {
    log_section "GPU Switching"
    
    # Check for hybrid graphics
    local gpu_count=$(lspci 2>/dev/null | grep -c -i vga || echo 0)
    
    if [[ $gpu_count -lt 2 ]]; then
        log_warn "No hybrid graphics detected"
        return 1
    fi
    
    echo "Available GPUs:"
    lspci 2>/dev/null | grep -i vga | nl
    
    echo ""
    echo "GPU switching methods:"
    echo "1) PRIME (NVIDIA Optimus)"
    echo "2) envycontrol"
    echo "3) optimus-manager"
    
    read -rp "Select method: " method
    
    case "$method" in
        1)
            log_info "Using PRIME"
            log_info "Run applications with: prime-run <application>"
            ;;
        2)
            if ! command -v envycontrol &>/dev/null; then
                log_info "Installing envycontrol..."
                yay -S envycontrol || paru -S envycontrol
            fi
            
            echo "Select mode:"
            echo "1) Integrated (iGPU only)"
            echo "2) NVIDIA (dGPU only)"
            echo "3) Hybrid"
            read -rp "Mode: " mode
            
            case "$mode" in
                1) sudo envycontrol -s integrated ;;
                2) sudo envycontrol -s nvidia ;;
                3) sudo envycontrol -s hybrid ;;
            esac
            ;;
        3)
            if ! command -v optimus-manager &>/dev/null; then
                log_info "Installing optimus-manager..."
                yay -S optimus-manager || paru -S optimus-manager
            fi
            
            echo "Select mode:"
            echo "1) Integrated"
            echo "2) NVIDIA"
            echo "3) Hybrid"
            read -rp "Mode: " mode
            
            case "$mode" in
                1) optimus-manager --switch integrated ;;
                2) optimus-manager --switch nvidia ;;
                3) optimus-manager --switch hybrid ;;
            esac
            ;;
    esac
}

# Monitor GPU
monitor_gpu() {
    log_section "GPU Monitor"
    
    local gpu_type=$(detect_gpu)
    
    case "$gpu_type" in
        nvidia)
            if command -v nvidia-smi &>/dev/null; then
                watch -n 1 nvidia-smi
            else
                log_error "nvidia-smi not found"
            fi
            ;;
        amd)
            if command -v radeontop &>/dev/null; then
                sudo radeontop
            else
                log_info "Installing radeontop..."
                sudo pacman -S radeontop
                sudo radeontop
            fi
            ;;
        intel)
            if command -v intel_gpu_top &>/dev/null; then
                sudo intel_gpu_top
            else
                log_info "Installing intel-gpu-tools..."
                sudo pacman -S intel-gpu-tools
                sudo intel_gpu_top
            fi
            ;;
        *)
            log_error "Unknown GPU type"
            ;;
    esac
}

# Configure GPU settings
configure_gpu() {
    log_section "GPU Configuration"
    
    local gpu_type=$(detect_gpu)
    
    case "$gpu_type" in
        nvidia)
            if command -v nvidia-settings &>/dev/null; then
                nvidia-settings
            else
                log_error "nvidia-settings not found"
            fi
            ;;
        *)
            log_info "No configuration tool available for this GPU"
            ;;
    esac
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        local gpu_type=$(detect_gpu)
        echo -e "Detected GPU: ${BOLD}$gpu_type${NC}"
        echo ""
        
        echo "Options:"
        echo "1) Show GPU info"
        echo "2) Monitor GPU"
        echo "3) Configure GPU"
        echo "4) Install GPU drivers"
        echo "5) Switch GPU (hybrid)"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) show_info; read -n1 -rp "Press any key..." ;;
            2) monitor_gpu ;;
            3) configure_gpu ;;
            4)
                echo "Select driver:"
                echo "1) NVIDIA"
                echo "2) AMD"
                echo "3) Intel"
                read -rp "Choice: " driver
                case "$driver" in
                    1) install_nvidia ;;
                    2) install_amd ;;
                    3) install_intel ;;
                esac
                read -n1 -rp "Press any key..."
                ;;
            5) switch_gpu; read -n1 -rp "Press any key..." ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-gpu [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  info              Show GPU information"
    echo "  monitor           Monitor GPU in real-time"
    echo "  config            Configure GPU settings"
    echo "  install [nvidia|amd|intel]  Install GPU drivers"
    echo "  switch            Switch GPU (hybrid graphics)"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        info) show_info ;;
        monitor) monitor_gpu ;;
        config) configure_gpu ;;
        install) 
            case "$2" in
                nvidia) install_nvidia ;;
                amd) install_amd ;;
                intel) install_intel ;;
                *) log_error "Unknown GPU type: $2"; usage; exit 1 ;;
            esac
            ;;
        switch) switch_gpu ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
