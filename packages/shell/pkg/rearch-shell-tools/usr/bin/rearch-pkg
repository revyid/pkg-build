#!/bin/bash
#
# rearch-pkg - Package management helper for ReArch OS
# Enhanced pacman wrapper with additional features
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  ___        _
 | _ \___ __| |_
 |  _/ _ (_-<  _|
 |_| \___/__/\__|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Package Manager for ReArch OS${NC}\n"
}

# Search packages
search_pkg() {
    local query="$1"
    
    if [[ -z "$query" ]]; then
        log_error "Please specify search query"
        return 1
    fi
    
    log_section "Search Results for '$query'"
    
    echo -e "${BOLD}Official Repository:${NC}"
    pacman -Ss "$query" 2>/dev/null | head -20
    
    # Search AUR if helper available
    if command -v yay &>/dev/null; then
        echo ""
        echo -e "${BOLD}AUR:${NC}"
        yay -Ss "$query" 2>/dev/null | head -10
    elif command -v paru &>/dev/null; then
        echo ""
        echo -e "${BOLD}AUR:${NC}"
        paru -Ss "$query" 2>/dev/null | head -10
    fi
}

# Show package info
pkg_info() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    log_section "Package Information: $pkg"
    
    if pacman -Qi "$pkg" &>/dev/null; then
        pacman -Qi "$pkg"
    elif pacman -Si "$pkg" &>/dev/null; then
        pacman -Si "$pkg"
    else
        log_error "Package not found: $pkg"
    fi
}

# List installed packages
list_installed() {
    log_section "Installed Packages"
    
    local count=$(pacman -Qq 2>/dev/null | wc -l)
    log_info "Total packages: $count"
    
    echo ""
    echo -e "${BOLD}Recently installed:${NC}"
    grep "\[ALPM\] installed" /var/log/pacman.log 2>/dev/null | tail -10 | awk '{print $4}' | while read -r pkg; do
        echo "  - $pkg"
    done
}

# Show package files
pkg_files() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    log_section "Files in $pkg"
    pacman -Ql "$pkg" 2>/dev/null | head -50 || log_error "Package not found"
}

# Find package owning file
find_owner() {
    local file="$1"
    
    if [[ -z "$file" ]]; then
        log_error "Please specify file path"
        return 1
    fi
    
    log_section "Package Owning $file"
    pacman -Qo "$file" 2>/dev/null || log_error "No package owns this file"
}

# Show package dependencies
pkg_deps() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    log_section "Dependencies of $pkg"
    pacman -Si "$pkg" 2>/dev/null | grep "Depends On" || log_error "Package not found"
}

# Show reverse dependencies
pkg_rdeps() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    log_section "Packages Depending on $pkg"
    pacman -Qq 2>/dev/null | while read -r p; do
        if pacman -Qi "$p" 2>/dev/null | grep "Depends On" | grep -q "$pkg"; then
            echo "  - $p"
        fi
    done
}

# Clean package cache
clean_cache() {
    log_section "Clean Package Cache"
    
    echo "Select option:"
    echo "1) Remove uninstalled packages from cache"
    echo "2) Keep only last 3 versions"
    echo "3) Remove all cache"
    
    read -rp "Choice: " choice
    
    case "$choice" in
        1)
            if command -v paccache &>/dev/null; then
                sudo paccache -ruk0
            else
                log_warn "paccache not installed (install pacman-contrib)"
            fi
            ;;
        2)
            if command -v paccache &>/dev/null; then
                sudo paccache -rk3
            else
                log_warn "paccache not installed (install pacman-contrib)"
            fi
            ;;
        3) sudo pacman -Scc ;;
        *) log_error "Invalid choice" ;;
    esac
}

# Show orphaned packages
show_orphans() {
    log_section "Orphaned Packages"
    
    local orphans=$(pacman -Qdtq 2>/dev/null)
    
    if [[ -z "$orphans" ]]; then
        log_success "No orphaned packages"
    else
        echo "$orphans"
        echo ""
        read -rp "Remove orphaned packages? [y/N]: " confirm
        if [[ "$confirm" =~ ^[Yy]$ ]]; then
            echo "$orphans" | sudo pacman -Rns -
        fi
    fi
}

# Show package statistics
pkg_stats() {
    log_section "Package Statistics"
    
    local total=$(pacman -Qq 2>/dev/null | wc -l)
    local explicit=$(pacman -Qqe 2>/dev/null | wc -l)
    local deps=$((total - explicit))
    local aur=$(pacman -Qqm 2>/dev/null | wc -l)
    local foreign=$(pacman -Qqd 2>/dev/null | wc -l)
    
    echo -e "${BOLD}Total packages:${NC}     $total"
    echo -e "${BOLD}Explicitly installed:${NC} $explicit"
    echo -e "${BOLD}Dependencies:${NC}       $deps"
    echo -e "${BOLD}AUR packages:${NC}       $aur"
    echo ""
    
    echo -e "${BOLD}Largest packages:${NC}"
    pacman -Qi 2>/dev/null | awk '/^Name/{name=$3} /^Installed Size/{print $4, name}' | sort -rn | head -10
}

# Update package database
update_db() {
    log_section "Update Package Database"
    sudo pacman -Sy
}

# Upgrade system
upgrade_system() {
    log_section "Upgrade System"
    sudo pacman -Syu
}

# Install package
install_pkg() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    log_section "Install $pkg"
    
    # Check if in official repos
    if pacman -Ss "^$pkg$" &>/dev/null; then
        sudo pacman -S "$pkg"
    else
        # Try AUR
        if command -v yay &>/dev/null; then
            yay -S "$pkg"
        elif command -v paru &>/dev/null; then
            paru -S "$pkg"
        else
            log_error "Package not found and no AUR helper installed"
        fi
    fi
}

# Remove package
remove_pkg() {
    local pkg="$1"
    
    if [[ -z "$pkg" ]]; then
        log_error "Please specify package name"
        return 1
    fi
    
    log_section "Remove $pkg"
    sudo pacman -Rns "$pkg"
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        echo "Options:"
        echo "1) Search packages"
        echo "2) Package info"
        echo "3) List installed packages"
        echo "4) Find package owning file"
        echo "5) Show orphaned packages"
        echo "6) Clean package cache"
        echo "7) Package statistics"
        echo "8) Update database"
        echo "9) Upgrade system"
        echo "10) Install package"
        echo "11) Remove package"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1)
                read -rp "Search query: " query
                search_pkg "$query"
                read -n1 -rp "Press any key..."
                ;;
            2)
                read -rp "Package name: " pkg
                pkg_info "$pkg"
                read -n1 -rp "Press any key..."
                ;;
            3) list_installed; read -n1 -rp "Press any key..." ;;
            4)
                read -rp "File path: " file
                find_owner "$file"
                read -n1 -rp "Press any key..."
                ;;
            5) show_orphans; read -n1 -rp "Press any key..." ;;
            6) clean_cache; read -n1 -rp "Press any key..." ;;
            7) pkg_stats; read -n1 -rp "Press any key..." ;;
            8) update_db; read -n1 -rp "Press any key..." ;;
            9) upgrade_system; read -n1 -rp "Press any key..." ;;
            10)
                read -rp "Package name: " pkg
                install_pkg "$pkg"
                read -n1 -rp "Press any key..."
                ;;
            11)
                read -rp "Package name: " pkg
                remove_pkg "$pkg"
                read -n1 -rp "Press any key..."
                ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-pkg [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  search QUERY      Search packages"
    echo "  info PKG          Show package info"
    echo "  list              List installed packages"
    echo "  files PKG         Show package files"
    echo "  owner FILE        Find package owning file"
    echo "  deps PKG          Show package dependencies"
    echo "  orphans           Show orphaned packages"
    echo "  clean             Clean package cache"
    echo "  stats             Show package statistics"
    echo "  update            Update package database"
    echo "  upgrade           Upgrade system"
    echo "  install PKG       Install package"
    echo "  remove PKG        Remove package"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        search) search_pkg "$2" ;;
        info) pkg_info "$2" ;;
        list) list_installed ;;
        files) pkg_files "$2" ;;
        owner) find_owner "$2" ;;
        deps) pkg_deps "$2" ;;
        orphans) show_orphans ;;
        clean) clean_cache ;;
        stats) pkg_stats ;;
        update) update_db ;;
        upgrade) upgrade_system ;;
        install) install_pkg "$2" ;;
        remove) remove_pkg "$2" ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
