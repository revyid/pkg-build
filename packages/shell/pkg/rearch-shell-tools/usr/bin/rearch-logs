#!/bin/bash
#
# rearch-logs - Log viewer and manager for ReArch OS
# Simplified journalctl wrapper with filtering and search
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
LINES=50

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  _    ___   ___   ___
 | |  / _ \ / _ \ / __|
 | |_| (_) | (_) | (__
 |____\___/ \___/ \___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Log Viewer for ReArch OS${NC}\n"
}

# Show all logs
show_all() {
    local lines="${1:-$LINES}"
    log_section "All Logs (last $lines lines)"
    journalctl -n "$lines" --no-pager 2>/dev/null || echo "Unable to read logs"
}

# Show boot log
show_boot() {
    log_section "Current Boot Log"
    journalctl -b --no-pager 2>/dev/null | tail -$LINES || echo "Unable to read boot log"
}

# Show previous boot
show_previous_boot() {
    log_section "Previous Boot Log"
    journalctl -b -1 --no-pager 2>/dev/null | tail -$LINES || echo "Unable to read previous boot log"
}

# Show kernel logs
show_kernel() {
    local lines="${1:-$LINES}"
    log_section "Kernel Logs (last $lines lines)"
    journalctl -k -n "$lines" --no-pager 2>/dev/null || dmesg | tail -$lines
}

# Show service logs
show_service() {
    local service="$1"
    local lines="${2:-$LINES}"
    
    if [[ -z "$service" ]]; then
        log_error "Please specify service name"
        return 1
    fi
    
    [[ "$service" != *.* ]] && service="$service.service"
    
    log_section "Logs for $service (last $lines lines)"
    journalctl -u "$service" -n "$lines" --no-pager 2>/dev/null || echo "Unable to read service logs"
}

# Show error logs
show_errors() {
    local lines="${1:-$LINES}"
    log_section "Error Logs (last $lines lines)"
    journalctl -p err -n "$lines" --no-pager 2>/dev/null || echo "Unable to read error logs"
}

# Show warning logs
show_warnings() {
    local lines="${1:-$LINES}"
    log_section "Warning Logs (last $lines lines)"
    journalctl -p warning -n "$lines" --no-pager 2>/dev/null || echo "Unable to read warning logs"
}

# Search logs
search_logs() {
    local query="$1"
    local lines="${2:-$LINES}"
    
    if [[ -z "$query" ]]; then
        log_error "Please specify search query"
        return 1
    fi
    
    log_section "Search Results for '$query'"
    journalctl --grep="$query" -n "$lines" --no-pager 2>/dev/null || {
        # Fallback to grep
        journalctl --no-pager 2>/dev/null | grep -i "$query" | tail -$lines
    }
}

# Show logs since
show_since() {
    local time="$1"
    
    if [[ -z "$time" ]]; then
        log_error "Please specify time (e.g., '1 hour ago', '2024-01-01')"
        return 1
    fi
    
    log_section "Logs since $time"
    journalctl --since="$time" --no-pager 2>/dev/null || echo "Unable to read logs"
}

# Follow logs
follow_logs() {
    local service="$1"
    
    log_info "Following logs (Ctrl+C to exit)..."
    
    if [[ -n "$service" ]]; then
        [[ "$service" != *.* ]] && service="$service.service"
        journalctl -u "$service" -f 2>/dev/null
    else
        journalctl -f 2>/dev/null
    fi
}

# Clean logs
clean_logs() {
    log_section "Clean Logs"
    
    echo "Select retention period:"
    echo "1) Keep last 24 hours"
    echo "2) Keep last 7 days"
    echo "3) Keep last 30 days"
    echo "4) Vacuum by size"
    
    read -rp "Choice: " choice
    
    case "$choice" in
        1) sudo journalctl --vacuum-time=1d ;;
        2) sudo journalctl --vacuum-time=7d ;;
        3) sudo journalctl --vacuum-time=30d ;;
        4)
            read -rp "Enter size (e.g., 500M, 1G): " size
            sudo journalctl --vacuum-size="$size"
            ;;
        *) log_error "Invalid choice" ;;
    esac
}

# Show disk usage
show_disk_usage() {
    log_section "Log Disk Usage"
    
    journalctl --disk-usage 2>/dev/null || echo "Unable to get disk usage"
    
    echo ""
    echo -e "${BOLD}Log directories:${NC}"
    du -sh /var/log/journal 2>/dev/null || echo "  N/A"
    du -sh /var/log 2>/dev/null || echo "  N/A"
}

# List boots
list_boots() {
    log_section "Boot History"
    journalctl --list-boots --no-pager 2>/dev/null || echo "Unable to list boots"
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        echo "Options:"
        echo "1) Show all logs"
        echo "2) Show boot log"
        echo "3) Show kernel logs"
        echo "4) Show service logs"
        echo "5) Show error logs"
        echo "6) Show warning logs"
        echo "7) Search logs"
        echo "8) Show logs since"
        echo "9) Follow logs"
        echo "10) Clean logs"
        echo "11) Show disk usage"
        echo "12) List boots"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) show_all; read -n1 -rp "Press any key..." ;;
            2) show_boot; read -n1 -rp "Press any key..." ;;
            3) show_kernel; read -n1 -rp "Press any key..." ;;
            4)
                read -rp "Service name: " service
                show_service "$service"
                read -n1 -rp "Press any key..."
                ;;
            5) show_errors; read -n1 -rp "Press any key..." ;;
            6) show_warnings; read -n1 -rp "Press any key..." ;;
            7)
                read -rp "Search query: " query
                search_logs "$query"
                read -n1 -rp "Press any key..."
                ;;
            8)
                read -rp "Time (e.g., '1 hour ago'): " time
                show_since "$time"
                read -n1 -rp "Press any key..."
                ;;
            9)
                read -rp "Service name (optional): " service
                follow_logs "$service"
                ;;
            10) clean_logs; read -n1 -rp "Press any key..." ;;
            11) show_disk_usage; read -n1 -rp "Press any key..." ;;
            12) list_boots; read -n1 -rp "Press any key..." ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-logs [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  all [LINES]       Show all logs"
    echo "  boot              Show current boot log"
    echo "  kernel [LINES]    Show kernel logs"
    echo "  service NAME      Show service logs"
    echo "  errors [LINES]    Show error logs"
    echo "  warnings [LINES]  Show warning logs"
    echo "  search QUERY      Search logs"
    echo "  since TIME        Show logs since time"
    echo "  follow [SERVICE]  Follow logs in real-time"
    echo "  clean             Clean old logs"
    echo "  usage             Show disk usage"
    echo "  boots             List boot history"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        all) show_all "$2" ;;
        boot) show_boot ;;
        kernel) show_kernel "$2" ;;
        service) show_service "$2" "$3" ;;
        errors) show_errors "$2" ;;
        warnings) show_warnings "$2" ;;
        search) search_logs "$2" "$3" ;;
        since) show_since "$2" ;;
        follow) follow_logs "$2" ;;
        clean) clean_logs ;;
        usage) show_disk_usage ;;
        boots) list_boots ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
