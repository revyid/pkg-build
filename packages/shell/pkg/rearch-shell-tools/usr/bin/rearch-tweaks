#!/bin/bash
#
# rearch-tweaks - System tweaks and optimizations for ReArch OS
# Apply various performance and usability tweaks
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  _____      _       _
 |_   _|__ _| |_ _ _(_)__ _ ___
   | |/ _ \` |  _| '_| / _` (_-<
   |_|\___/ \__|_| |_\__,_/__/
EOF
    echo -e "${NC}"
    echo -e "${BOLD}System Tweaks for ReArch OS${NC}\n"
}

# Gaming tweaks
apply_gaming() {
    log_section "Gaming Tweaks"
    
    log_info "Applying gaming optimizations..."
    
    # CPU governor
    echo 'GOVERNOR="performance"' | sudo tee /etc/default/cpufrequtils > /dev/null
    
    # Swappiness
    echo "vm.swappiness=10" | sudo tee /etc/sysctl.d/99-gaming.conf > /dev/null
    echo "vm.vfs_cache_pressure=50" | sudo tee -a /etc/sysctl.d/99-gaming.conf > /dev/null
    
    # Kernel parameters for gaming
    local gaming_params="quiet splash mitigations=off nowatchdog"
    sudo sed -i "s/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT=\"$gaming_params\"/" /etc/default/grub
    sudo grub-mkconfig -o /boot/grub/grub.cfg
    
    # Enable gamemode if installed
    if command -v gamemoded &>/dev/null; then
        systemctl --user enable gamemoded 2>/dev/null || true
        log_success "Gamemode enabled"
    fi
    
    # Install gaming packages
    log_info "Recommended packages for gaming:"
    echo "  - steam"
    echo "  - wine-staging"
    echo "  - gamemode"
    echo "  - mangohud"
    
    log_success "Gaming tweaks applied"
    log_warn "Please reboot for all changes to take effect"
}

# Laptop tweaks
apply_laptop() {
    log_section "Laptop Tweaks"
    
    log_info "Applying laptop optimizations..."
    
    # Install TLP
    if ! command -v tlp &>/dev/null; then
        log_info "Installing TLP..."
        sudo pacman -S tlp tlp-rdw
    fi
    
    # Enable TLP
    sudo systemctl enable --now tlp
    
    # Laptop mode
    echo "vm.laptop_mode=5" | sudo tee /etc/sysctl.d/99-laptop.conf > /dev/null
    
    # Power saving
    echo "ACTION==\"add\", SUBSYSTEM==\"scsi_host\", KERNEL==\"host*\", ATTR{link_power_management_policy}=\"min_power\"" | sudo tee /etc/udev/rules.d/50-sata-power-save.rules > /dev/null
    
    log_success "Laptop tweaks applied"
}

# Desktop tweaks
apply_desktop() {
    log_section "Desktop Tweaks"
    
    log_info "Applying desktop optimizations..."
    
    # CPU governor
    echo 'GOVERNOR="schedutil"' | sudo tee /etc/default/cpufrequtils > /dev/null
    
    # Balanced swappiness
    echo "vm.swappiness=20" | sudo tee /etc/sysctl.d/99-desktop.conf > /dev/null
    
    # Network optimizations
    cat << 'EOF' | sudo tee /etc/sysctl.d/99-network.conf > /dev/null
net.core.rmem_max = 134217728
net.core.wmem_max = 134217728
net.ipv4.tcp_rmem = 4096 87380 134217728
net.ipv4.tcp_wmem = 4096 65536 134217728
net.core.netdev_max_backlog = 30000
net.ipv4.tcp_congestion_control = bbr
EOF
    
    log_success "Desktop tweaks applied"
}

# Server tweaks
apply_server() {
    log_section "Server Tweaks"
    
    log_info "Applying server optimizations..."
    
    # Conservative settings for stability
    echo "vm.swappiness=10" | sudo tee /etc/sysctl.d/99-server.conf > /dev/null
    echo "vm.dirty_ratio=15" | sudo tee -a /etc/sysctl.d/99-server.conf > /dev/null
    echo "vm.dirty_background_ratio=5" | sudo tee -a /etc/sysctl.d/99-server.conf > /dev/null
    
    # Increase file handles
    echo "* soft nofile 65536" | sudo tee -a /etc/security/limits.conf > /dev/null
    echo "* hard nofile 65536" | sudo tee -a /etc/security/limits.conf > /dev/null
    
    # Kernel parameters
    echo "kernel.sched_migration_cost_ns=5000000" | sudo tee -a /etc/sysctl.d/99-server.conf > /dev/null
    
    log_success "Server tweaks applied"
}

# SSD optimizations
apply_ssd() {
    log_section "SSD Optimizations"
    
    log_info "Applying SSD optimizations..."
    
    # Enable TRIM
    sudo systemctl enable --now fstrim.timer
    
    # I/O scheduler for SSD
    echo 'ACTION=="add|change", KERNEL=="sd[a-z]*|mmcblk[0-9]*", ATTR{queue/rotational}=="0", ATTR{queue/scheduler}="mq-deadline"' | sudo tee /etc/udev/rules.d/60-ioscheduler.rules > /dev/null
    
    # Disable swap on SSD (if enough RAM)
    local mem_gb=$(free -g | grep "^Mem:" | awk '{print $2}')
    if [[ $mem_gb -ge 8 ]]; then
        log_info "Sufficient RAM detected, reducing swap usage"
        echo "vm.swappiness=1" | sudo tee /etc/sysctl.d/99-ssd.conf > /dev/null
    fi
    
    # Enable noatime
    log_info "Consider adding 'noatime' to your fstab mount options"
    
    log_success "SSD optimizations applied"
}

# Disable unnecessary services
disable_services() {
    log_section "Disable Unnecessary Services"
    
    local services=(
        "bluetooth"
        "cups"
        "ModemManager"
    )
    
    echo "Services that can be disabled:"
    for svc in "${services[@]}"; do
        if systemctl list-unit-files | grep -q "^$svc"; then
            echo "  - $svc"
        fi
    done
    
    echo ""
    read -rp "Enter service name to disable: " svc
    
    if [[ -n "$svc" ]]; then
        sudo systemctl disable --now "$svc" 2>/dev/null && log_success "$svc disabled" || log_error "Failed to disable $svc"
    fi
}

# Show current tweaks
show_tweaks() {
    log_section "Current System Tweaks"
    
    echo -e "${BOLD}Sysctl Settings:${NC}"
    sysctl -a 2>/dev/null | grep -E "swappiness|vfs_cache|dirty_ratio" | head -10
    
    echo ""
    echo -e "${BOLD}CPU Governor:${NC}"
    cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo "N/A"
    
    echo ""
    echo -e "${BOLD}I/O Scheduler:${NC}"
    cat /sys/block/sda/queue/scheduler 2>/dev/null || echo "N/A"
    
    echo ""
    echo -e "${BOLD}Kernel Parameters:${NC}"
    cat /proc/cmdline | fold -s -w 60 | head -5
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        echo "Options:"
        echo "1) Gaming tweaks"
        echo "2) Laptop tweaks"
        echo "3) Desktop tweaks"
        echo "4) Server tweaks"
        echo "5) SSD optimizations"
        echo "6) Disable services"
        echo "7) Show current tweaks"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) apply_gaming; read -n1 -rp "Press any key..." ;;
            2) apply_laptop; read -n1 -rp "Press any key..." ;;
            3) apply_desktop; read -n1 -rp "Press any key..." ;;
            4) apply_server; read -n1 -rp "Press any key..." ;;
            5) apply_ssd; read -n1 -rp "Press any key..." ;;
            6) disable_services; read -n1 -rp "Press any key..." ;;
            7) show_tweaks; read -n1 -rp "Press any key..." ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-tweaks [COMMAND]"
    echo ""
    echo "Commands:"
    echo "  gaming            Apply gaming optimizations"
    echo "  laptop            Apply laptop optimizations"
    echo "  desktop           Apply desktop optimizations"
    echo "  server            Apply server optimizations"
    echo "  ssd               Apply SSD optimizations"
    echo "  disable           Disable unnecessary services"
    echo "  show              Show current tweaks"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        gaming) apply_gaming ;;
        laptop) apply_laptop ;;
        desktop) apply_desktop ;;
        server) apply_server ;;
        ssd) apply_ssd ;;
        disable) disable_services ;;
        show) show_tweaks ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
