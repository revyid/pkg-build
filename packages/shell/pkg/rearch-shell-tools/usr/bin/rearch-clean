#!/bin/bash
#
# rearch-clean - Intelligent system cleaner for ReArch OS
# Deep-cleans cache, orphaned packages, log bloat, and temporary files
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
DRY_RUN=false
VERBOSE=false
CLEAN_LEVEL="standard"  # minimal, standard, aggressive

# Statistics
TOTAL_FREED=0
ITEMS_CLEANED=0

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
   ___ _   _ ___  ___   _____ _ _
  / __| | | | _ \/ __| / __(_) | |
 | (__| |_| |   /\__ \/ _|| | | |
  \___|\___/|_|_\|___/\__||_|_|_|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Intelligent System Cleaner for ReArch OS${NC}\n"
}

# Calculate size
calc_size() {
    local path="$1"
    if [[ -e "$path" ]]; then
        du -sb "$path" 2>/dev/null | awk '{print $1}' || echo 0
    else
        echo 0
    fi
}

# Format bytes
format_size() {
    local bytes=$1
    if [[ $bytes -ge 1073741824 ]]; then
        echo "$(echo "scale=2; $bytes/1073741824" | bc) GB"
    elif [[ $bytes -ge 1048576 ]]; then
        echo "$(echo "scale=2; $bytes/1048576" | bc) MB"
    elif [[ $bytes -ge 1024 ]]; then
        echo "$(echo "scale=2; $bytes/1024" | bc) KB"
    else
        echo "${bytes} B"
    fi
}

# Clean pacman cache
clean_pacman_cache() {
    log_section "Pacman Cache"
    
    local cache_dir="/var/cache/pacman/pkg"
    local before_size=$(calc_size "$cache_dir")
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean: $cache_dir"
        local pkg_count=$(find "$cache_dir" -name "*.pkg.tar.*" 2>/dev/null | wc -l)
        log_info "Packages to remove: $pkg_count"
        return
    fi
    
    # Remove uninstalled packages from cache
    if command -v paccache &>/dev/null; then
        paccache -ruk0 2>/dev/null || true
        case "$CLEAN_LEVEL" in
            minimal) paccache -rk1 2>/dev/null || true ;;
            standard) paccache -rk2 2>/dev/null || true ;;
            aggressive) paccache -rk0 2>/dev/null || true ;;
        esac
    else
        # Manual cleanup - keep only installed packages
        local installed_pkgs=$(pacman -Qq 2>/dev/null | sort -u)
        for pkg_file in "$cache_dir"/*.pkg.tar.* 2>/dev/null; do
            [[ -f "$pkg_file" ]] || continue
            local pkg_name=$(basename "$pkg_file" | sed 's/-[0-9].*//')
            if ! echo "$installed_pkgs" | grep -qx "$pkg_name"; then
                rm -f "$pkg_file"
                ((ITEMS_CLEANED++))
            fi
        done
    fi
    
    local after_size=$(calc_size "$cache_dir")
    local freed=$((before_size - after_size))
    TOTAL_FREED=$((TOTAL_FREED + freed))
    
    log_success "Freed: $(format_size $freed)"
}

# Clean orphaned packages
clean_orphans() {
    log_section "Orphaned Packages"
    
    local orphans=$(pacman -Qdtq 2>/dev/null || true)
    
    if [[ -z "$orphans" ]]; then
        log_info "No orphaned packages found"
        return
    fi
    
    local orphan_count=$(echo "$orphans" | wc -l)
    log_info "Found $orphan_count orphaned packages"
    
    if [[ "$VERBOSE" == true ]]; then
        echo "$orphans" | head -20 | while read -r pkg; do
            log_info "  - $pkg"
        done
        [[ $orphan_count -gt 20 ]] && log_info "  ... and $((orphan_count - 20)) more"
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        return
    fi
    
    read -rp "Remove orphaned packages? [y/N]: " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo "$orphans" | pacman -Rns - 2>/dev/null || true
        ITEMS_CLEANED=$((ITEMS_CLEANED + orphan_count))
        log_success "Removed $orphan_count orphaned packages"
    fi
}

# Clean log files
clean_logs() {
    log_section "Log Files"
    
    local log_dir="/var/log"
    local journal_dir="/var/log/journal"
    local before_size=$(calc_size "$log_dir")
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean: $log_dir"
        return
    fi
    
    # Clean journal logs
    if command -v journalctl &>/dev/null; then
        case "$CLEAN_LEVEL" in
            minimal) journalctl --vacuum-time=30d 2>/dev/null || true ;;
            standard) journalctl --vacuum-time=14d 2>/dev/null || true ;;
            aggressive) journalctl --vacuum-time=3d 2>/dev/null || true ;;
        esac
    fi
    
    # Clean old log files
    find "$log_dir" -name "*.log.*" -type f -mtime +30 -delete 2>/dev/null || true
    find "$log_dir" -name "*.log.old" -type f -delete 2>/dev/null || true
    find "$log_dir" -name "*.gz" -type f -mtime +60 -delete 2>/dev/null || true
    
    # Truncate large logs
    find "$log_dir" -name "*.log" -type f -size +100M -exec sh -c '> {}' \; 2>/dev/null || true
    
    local after_size=$(calc_size "$log_dir")
    local freed=$((before_size - after_size))
    TOTAL_FREED=$((TOTAL_FREED + freed))
    
    log_success "Freed: $(format_size $freed)"
}

# Clean user cache
clean_user_cache() {
    log_section "User Cache"
    
    local cache_dirs=(
        "$HOME/.cache"
        "$HOME/.thumbnails"
        "$HOME/.local/share/Trash"
    )
    
    local before_size=0
    for dir in "${cache_dirs[@]}"; do
        before_size=$((before_size + $(calc_size "$dir")))
    done
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean user cache directories"
        return
    fi
    
    # Clean browser caches
    find "$HOME/.cache" -name "*Cache*" -type d -exec rm -rf {} + 2>/dev/null || true
    find "$HOME/.cache" -name "*cache*" -type d -exec rm -rf {} + 2>/dev/null || true
    
    # Clean thumbnails
    rm -rf "$HOME/.thumbnails/large"/* 2>/dev/null || true
    rm -rf "$HOME/.thumbnails/normal"/* 2>/dev/null || true
    
    # Clean application caches
    rm -rf "$HOME/.cache/mozilla"/* 2>/dev/null || true
    rm -rf "$HOME/.cache/google-chrome"/* 2>/dev/null || true
    rm -rf "$HOME/.cache/spotify"/* 2>/dev/null || true
    rm -rf "$HOME/.cache/telegram-desktop"/* 2>/dev/null || true
    
    # Empty trash
    rm -rf "$HOME/.local/share/Trash/files"/* 2>/dev/null || true
    rm -rf "$HOME/.local/share/Trash/info"/* 2>/dev/null || true
    
    local after_size=0
    for dir in "${cache_dirs[@]}"; do
        after_size=$((after_size + $(calc_size "$dir")))
    done
    
    local freed=$((before_size - after_size))
    TOTAL_FREED=$((TOTAL_FREED + freed))
    
    log_success "Freed: $(format_size $freed)"
}

# Clean temporary files
clean_temp() {
    log_section "Temporary Files"
    
    local temp_dirs=(
        "/tmp"
        "/var/tmp"
    )
    
    local before_size=0
    for dir in "${temp_dirs[@]}"; do
        before_size=$((before_size + $(calc_size "$dir")))
    done
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean temporary directories"
        return
    fi
    
    # Clean /tmp (be careful with running processes)
    find /tmp -type f -atime +7 -delete 2>/dev/null || true
    find /tmp -type d -empty -delete 2>/dev/null || true
    
    # Clean /var/tmp
    find /var/tmp -type f -atime +7 -delete 2>/dev/null || true
    
    local after_size=0
    for dir in "${temp_dirs[@]}"; do
        after_size=$((after_size + $(calc_size "$dir")))
    done
    
    local freed=$((before_size - after_size))
    TOTAL_FREED=$((TOTAL_FREED + freed))
    
    log_success "Freed: $(format_size $freed)"
}

# Clean AUR build cache
clean_aur_cache() {
    log_section "AUR Build Cache"
    
    local aur_dirs=(
        "$HOME/.cache/yay"
        "$HOME/.cache/paru"
        "$HOME/.cache/trizen"
        "/tmp/yay-*"
    )
    
    local before_size=0
    for dir in "${aur_dirs[@]}"; do
        before_size=$((before_size + $(calc_size "$dir")))
    done
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean AUR build cache"
        return
    fi
    
    # Clean yay cache
    if [[ -d "$HOME/.cache/yay" ]]; then
        find "$HOME/.cache/yay" -name "*.pkg.tar.*" -type f -mtime +7 -delete 2>/dev/null || true
        find "$HOME/.cache/yay" -name "src" -type d -exec rm -rf {} + 2>/dev/null || true
        find "$HOME/.cache/yay" -name "pkg" -type d -exec rm -rf {} + 2>/dev/null || true
    fi
    
    # Clean paru cache
    if [[ -d "$HOME/.cache/paru" ]]; then
        rm -rf "$HOME/.cache/paru/clone"/* 2>/dev/null || true
    fi
    
    local after_size=0
    for dir in "${aur_dirs[@]}"; do
        after_size=$((after_size + $(calc_size "$dir")))
    done
    
    local freed=$((before_size - after_size))
    TOTAL_FREED=$((TOTAL_FREED + freed))
    
    log_success "Freed: $(format_size $freed)"
}

# Clean flatpak cache
clean_flatpak() {
    log_section "Flatpak Cache"
    
    if ! command -v flatpak &>/dev/null; then
        log_info "Flatpak not installed, skipping"
        return
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean unused Flatpak runtimes"
        return
    fi
    
    # Remove unused runtimes
    flatpak uninstall --unused -y 2>/dev/null || true
    
    # Clean Flatpak cache
    rm -rf "$HOME/.var/app"/*/cache/* 2>/dev/null || true
    
    log_success "Flatpak cache cleaned"
}

# Clean docker
clean_docker() {
    log_section "Docker"
    
    if ! command -v docker &>/dev/null; then
        log_info "Docker not installed, skipping"
        return
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        log_info "Would clean Docker resources"
        return
    fi
    
    # Remove dangling images
    docker image prune -f 2>/dev/null || true
    
    # Remove stopped containers
    docker container prune -f 2>/dev/null || true
    
    # Remove unused volumes
    docker volume prune -f 2>/dev/null || true
    
    # Remove unused networks
    docker network prune -f 2>/dev/null || true
    
    # Full system prune (aggressive only)
    if [[ "$CLEAN_LEVEL" == "aggressive" ]]; then
        docker system prune -af 2>/dev/null || true
    fi
    
    log_success "Docker resources cleaned"
}

# Clean old kernels
clean_kernels() {
    log_section "Old Kernels"
    
    local current_kernel=$(uname -r | cut -d- -f1)
    local kernel_pkgs=$(pacman -Qq | grep -E "^linux-[0-9]" | grep -v "$current_kernel" 2>/dev/null || true)
    
    if [[ -z "$kernel_pkgs" ]]; then
        log_info "No old kernels found"
        return
    fi
    
    local kernel_count=$(echo "$kernel_pkgs" | wc -l)
    log_info "Found $kernel_count old kernel(s)"
    
    if [[ "$VERBOSE" == true ]]; then
        echo "$kernel_pkgs" | while read -r pkg; do
            log_info "  - $pkg"
        done
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        return
    fi
    
    read -rp "Remove old kernels? [y/N]: " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo "$kernel_pkgs" | pacman -Rns - 2>/dev/null || true
        ITEMS_CLEANED=$((ITEMS_CLEANED + kernel_count))
        log_success "Removed old kernels"
    fi
}

# Show summary
show_summary() {
    echo -e "\n${GREEN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}${BOLD}  Cleaning Complete!${NC}"
    echo -e "${GREEN}${BOLD}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${CYAN}Total Space Freed:${NC} $(format_size $TOTAL_FREED)"
    echo -e "  ${CYAN}Items Cleaned:${NC} $ITEMS_CLEANED"
    echo ""
}

# Usage
usage() {
    echo "Usage: rearch-clean [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --dry-run          Show what would be cleaned without doing it"
    echo "  --verbose          Show detailed output"
    echo "  --minimal          Minimal cleaning (safe)"
    echo "  --standard         Standard cleaning (default)"
    echo "  --aggressive       Aggressive cleaning (be careful)"
    echo "  --help, -h         Show this help message"
    echo ""
    echo "Cleaning categories:"
    echo "  - Pacman cache"
    echo "  - Orphaned packages"
    echo "  - Log files"
    echo "  - User cache"
    echo "  - Temporary files"
    echo "  - AUR build cache"
    echo "  - Flatpak cache"
    echo "  - Docker resources"
    echo "  - Old kernels"
}

# Main
main() {
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run) DRY_RUN=true ;;
            --verbose) VERBOSE=true ;;
            --minimal) CLEAN_LEVEL="minimal" ;;
            --standard) CLEAN_LEVEL="standard" ;;
            --aggressive) CLEAN_LEVEL="aggressive" ;;
            --help|-h) usage; exit 0 ;;
            *) log_error "Unknown option: $1"; usage; exit 1 ;;
        esac
        shift
    done
    
    # Check root for some operations
    if [[ $EUID -ne 0 ]]; then
        log_warn "Some operations require root. Run with sudo for full functionality."
    fi
    
    show_banner
    
    if [[ "$DRY_RUN" == true ]]; then
        log_warn "DRY RUN MODE - No changes will be made"
    fi
    
    log_info "Clean level: $CLEAN_LEVEL"
    echo ""
    
    # Run cleaners
    clean_pacman_cache
    clean_orphans
    clean_logs
    clean_user_cache
    clean_temp
    clean_aur_cache
    clean_flatpak
    clean_docker
    clean_kernels
    
    show_summary
}

main "$@"
