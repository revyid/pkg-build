#!/bin/bash
#
# rearch-boot - Boot manager for ReArch OS
# Manage GRUB, boot entries, and boot parameters
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
GRUB_CFG="/boot/grub/grub.cfg"
GRUB_DEFAULT="/etc/default/grub"

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_section() { echo -e "\n${CYAN}${BOLD}▶ $1${NC}"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  ___              _
 | _ ) ___ _ _  _ | |__ _ _ ___
 | _ \/ _ \ ' \/ _` / _` |_ / -_)
 |___/\___/_||_\__,_\__,_/__\___|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Boot Manager for ReArch OS${NC}\n"
}

# Show boot info
show_info() {
    log_section "Boot Information"
    
    echo -e "${BOLD}Boot Mode:${NC}"
    if [[ -d /sys/firmware/efi/efivars ]]; then
        echo "  UEFI"
        echo -e "${BOLD}EFI Partition:${NC}"
        findmnt -n /boot/efi 2>/dev/null || echo "  Not mounted"
    else
        echo "  BIOS/Legacy"
    fi
    
    echo ""
    echo -e "${BOLD}Current Kernel:${NC} $(uname -r)"
    echo -e "${BOLD}Command Line:${NC}"
    cat /proc/cmdline | fold -s -w 60 | sed 's/^/  /'
    
    echo ""
    echo -e "${BOLD}Bootloader:${NC}"
    if [[ -f "$GRUB_CFG" ]]; then
        echo "  GRUB2"
        grep "REArch" "$GRUB_CFG" 2>/dev/null | head -1 | sed 's/^/  /' || true
    fi
}

# List boot entries
list_entries() {
    log_section "Boot Entries"
    
    if [[ -f "$GRUB_CFG" ]]; then
        echo -e "${BOLD}GRUB Menu Entries:${NC}"
        grep -E "^menuentry|^submenu" "$GRUB_CFG" 2>/dev/null | nl -w2 -s') ' | sed 's/menuentry //; s/submenu //; s/ {.*//; s/"//g'
    else
        log_error "GRUB config not found"
    fi
}

# Set default entry
set_default() {
    local entry="$1"
    
    if [[ -z "$entry" ]]; then
        log_error "Please specify entry number or name"
        return 1
    fi
    
    log_section "Setting Default Boot Entry"
    
    # If it's a number, convert to entry name
    if [[ "$entry" =~ ^[0-9]+$ ]]; then
        entry=$(grep -E "^menuentry|^submenu" "$GRUB_CFG" 2>/dev/null | sed -n "${entry}p" | sed 's/menuentry "//; s/" {.*//')
        if [[ -z "$entry" ]]; then
            log_error "Invalid entry number"
            return 1
        fi
    fi
    
    log_info "Setting default to: $entry"
    
    # Update GRUB default
    sudo sed -i "s/^GRUB_DEFAULT=.*/GRUB_DEFAULT=\"$entry\"/" "$GRUB_DEFAULT"
    
    # Regenerate GRUB config
    regenerate_grub
    
    log_success "Default entry set to: $entry"
}

# Set timeout
set_timeout() {
    local timeout="$1"
    
    if [[ -z "$timeout" ]]; then
        log_error "Please specify timeout in seconds"
        return 1
    fi
    
    log_section "Setting GRUB Timeout"
    
    sudo sed -i "s/^GRUB_TIMEOUT=.*/GRUB_TIMEOUT=$timeout/" "$GRUB_DEFAULT"
    
    regenerate_grub
    
    log_success "Timeout set to $timeout seconds"
}

# Regenerate GRUB config
regenerate_grub() {
    log_info "Regenerating GRUB config..."
    sudo grub-mkconfig -o "$GRUB_CFG"
}

# Edit kernel parameters
edit_params() {
    log_section "Edit Kernel Parameters"
    
    local current_params=$(grep "^GRUB_CMDLINE_LINUX_DEFAULT" "$GRUB_DEFAULT" | cut -d'"' -f2)
    
    echo "Current parameters:"
    echo "  $current_params"
    echo ""
    
    read -rp "Enter new parameters: " new_params
    
    if [[ -n "$new_params" ]]; then
        sudo sed -i "s/^GRUB_CMDLINE_LINUX_DEFAULT=.*/GRUB_CMDLINE_LINUX_DEFAULT=\"$new_params\"/" "$GRUB_DEFAULT"
        regenerate_grub
        log_success "Kernel parameters updated"
    fi
}

# Install GRUB
install_grub() {
    log_section "Install GRUB"
    
    echo "Select target:"
    echo "1) Install to disk (BIOS)"
    echo "2) Install to EFI partition (UEFI)"
    read -rp "Choice: " target
    
    case "$target" in
        1)
            lsblk -d -o NAME,SIZE,MODEL,TYPE | grep disk
            read -rp "Enter disk (e.g., /dev/sda): " disk
            sudo grub-install --target=i386-pc "$disk"
            ;;
        2)
            sudo grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=REArch
            ;;
        *)
            log_error "Invalid choice"
            return 1
            ;;
    esac
    
    regenerate_grub
    log_success "GRUB installed"
}

# Set theme
set_theme() {
    log_section "Set GRUB Theme"
    
    local themes_dir="/usr/share/grub/themes"
    
    if [[ -d "$themes_dir" ]]; then
        echo "Available themes:"
        ls -1 "$themes_dir" 2>/dev/null | nl
        
        read -rp "Select theme (number or name): " theme
        
        # If number, get name
        if [[ "$theme" =~ ^[0-9]+$ ]]; then
            theme=$(ls -1 "$themes_dir" 2>/dev/null | sed -n "${theme}p")
        fi
        
        if [[ -d "$themes_dir/$theme" ]]; then
            sudo sed -i "s|^#\?GRUB_THEME=.*|GRUB_THEME=\"$themes_dir/$theme/theme.txt\"|" "$GRUB_DEFAULT"
            regenerate_grub
            log_success "Theme set to: $theme"
        else
            log_error "Theme not found: $theme"
        fi
    else
        log_warn "No themes directory found"
    fi
}

# Show boot log
show_log() {
    log_section "Boot Log"
    
    journalctl -b 2>/dev/null | head -100 || {
        log_error "Unable to read boot log"
    }
}

# Analyze boot time
analyze_boot() {
    log_section "Boot Time Analysis"
    
    if command -v systemd-analyze &>/dev/null; then
        systemd-analyze
        
        echo ""
        echo -e "${BOLD}Critical Chain:${NC}"
        systemd-analyze critical-chain 2>/dev/null | head -20
        
        echo ""
        echo -e "${BOLD}Blame (slowest services):${NC}"
        systemd-analyze blame 2>/dev/null | head -20
    else
        log_error "systemd-analyze not available"
    fi
}

# Interactive menu
interactive_menu() {
    while true; do
        clear
        show_banner
        
        echo "Options:"
        echo "1) Show boot info"
        echo "2) List boot entries"
        echo "3) Set default entry"
        echo "4) Set timeout"
        echo "5) Edit kernel parameters"
        echo "6) Regenerate GRUB config"
        echo "7) Install GRUB"
        echo "8) Set theme"
        echo "9) Show boot log"
        echo "10) Analyze boot time"
        echo "0) Exit"
        echo ""
        
        read -rp "Select option: " choice
        
        case "$choice" in
            1) show_info; read -n1 -rp "Press any key..." ;;
            2) list_entries; read -n1 -rp "Press any key..." ;;
            3)
                list_entries
                read -rp "Entry number or name: " entry
                set_default "$entry"
                read -n1 -rp "Press any key..."
                ;;
            4)
                read -rp "Timeout in seconds: " timeout
                set_timeout "$timeout"
                read -n1 -rp "Press any key..."
                ;;
            5) edit_params; read -n1 -rp "Press any key..." ;;
            6) regenerate_grub; read -n1 -rp "Press any key..." ;;
            7) install_grub; read -n1 -rp "Press any key..." ;;
            8) set_theme; read -n1 -rp "Press any key..." ;;
            9) show_log; read -n1 -rp "Press any key..." ;;
            10) analyze_boot; read -n1 -rp "Press any key..." ;;
            0) exit 0 ;;
            *) log_error "Invalid option" ;;
        esac
    done
}

# Usage
usage() {
    echo "Usage: rearch-boot [COMMAND] [OPTIONS]"
    echo ""
    echo "Commands:"
    echo "  info              Show boot information"
    echo "  list              List boot entries"
    echo "  default ENTRY     Set default boot entry"
    echo "  timeout SECONDS   Set GRUB timeout"
    echo "  params            Edit kernel parameters"
    echo "  regenerate        Regenerate GRUB config"
    echo "  install           Install GRUB"
    echo "  theme             Set GRUB theme"
    echo "  log               Show boot log"
    echo "  analyze           Analyze boot time"
    echo "  interactive       Interactive menu (default)"
}

# Main
main() {
    show_banner
    
    case "${1:-interactive}" in
        info) show_info ;;
        list) list_entries ;;
        default) set_default "$2" ;;
        timeout) set_timeout "$2" ;;
        params) edit_params ;;
        regenerate) regenerate_grub ;;
        install) install_grub ;;
        theme) set_theme ;;
        log) show_log ;;
        analyze) analyze_boot ;;
        interactive) interactive_menu ;;
        --help|-h) usage; exit 0 ;;
        *) log_error "Unknown command: $1"; usage; exit 1 ;;
    esac
}

main "$@"
