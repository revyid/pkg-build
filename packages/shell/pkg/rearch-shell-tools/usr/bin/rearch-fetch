#!/bin/bash
#
# rearch-fetch - High-speed system information fetcher for ReArch OS
# A faster, more detailed alternative to neofetch/fastfetch with ReArch branding
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/rearch-fetch"
CACHE_FILE="$CACHE_DIR/sysinfo.cache"
CACHE_TTL=300  # 5 minutes

# ASCII Art
show_logo() {
    echo -e "${CYAN}"
    cat << 'EOF'
    ____  _______    ____             __
   / __ \/ ___/ /   / __ \____ ______/ /_
  / /_/ / /  / /   / /_/ / __ `/ ___/ __ \
 / _, _/ /__/ /___/ _, _/ /_/ (__  ) / / /
/_/ |_|\____/_____/_/ |_|\__,_/____/_/ /_/
EOF
    echo -e "${NC}"
}

# Get cached or fresh data
get_cached_or_fresh() {
    local key="$1"
    local cmd="$2"
    
    if [[ -f "$CACHE_FILE" ]] && [[ $(($(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0))) -lt $CACHE_TTL ]]; then
        grep "^$key:" "$CACHE_FILE" 2>/dev/null | cut -d: -f2- || eval "$cmd"
    else
        mkdir -p "$CACHE_DIR"
        local result=$(eval "$cmd")
        echo "$key:$result" >> "$CACHE_FILE"
        echo "$result"
    fi
}

# System information getters
get_os() {
    if [[ -f /etc/os-release ]]; then
        source /etc/os-release
        echo "${PRETTY_NAME:-$NAME}"
    else
        echo "Unknown"
    fi
}

get_kernel() {
    uname -r
}

get_uptime() {
    local uptime_sec=$(cat /proc/uptime | awk '{print int($1)}')
    local days=$((uptime_sec / 86400))
    local hours=$(((uptime_sec % 86400) / 3600))
    local minutes=$(((uptime_sec % 3600) / 60))
    
    if [[ $days -gt 0 ]]; then
        echo "${days}d ${hours}h ${minutes}m"
    elif [[ $hours -gt 0 ]]; then
        echo "${hours}h ${minutes}m"
    else
        echo "${minutes}m"
    fi
}

get_packages() {
    local pkg_count=0
    if command -v pacman &>/dev/null; then
        pkg_count=$(pacman -Qq 2>/dev/null | wc -l)
    fi
    if command -v flatpak &>/dev/null; then
        pkg_count=$((pkg_count + $(flatpak list 2>/dev/null | wc -l)))
    fi
    echo "$pkg_count"
}

get_shell() {
    echo "${SHELL##*/}"
}

get_de_wm() {
    if [[ -n "$XDG_CURRENT_DESKTOP" ]]; then
        echo "$XDG_CURRENT_DESKTOP"
    elif [[ -n "$DESKTOP_SESSION" ]]; then
        echo "$DESKTOP_SESSION"
    elif [[ -n "$WAYLAND_DISPLAY" ]]; then
        echo "Wayland"
    elif [[ -n "$DISPLAY" ]]; then
        echo "X11"
    else
        echo "TTY"
    fi
}

get_cpu() {
    grep -m1 'model name' /proc/cpuinfo 2>/dev/null | cut -d: -f2 | sed 's/^ *//' | sed 's/(R)//g; s/(TM)//g; s/CPU //g; s/@.*//g' | xargs
}

get_cpu_cores() {
    nproc
}

get_cpu_freq() {
    local freq=$(cat /proc/cpuinfo 2>/dev/null | grep "cpu MHz" | head -1 | awk '{print int($4)}')
    if [[ -n "$freq" ]]; then
        echo "${freq} MHz"
    else
        echo "Unknown"
    fi
}

get_memory() {
    local mem_info=$(free -m 2>/dev/null | grep "^Mem:")
    if [[ -n "$mem_info" ]]; then
        local total=$(echo "$mem_info" | awk '{print $2}')
        local used=$(echo "$mem_info" | awk '{print $3}')
        echo "${used}MiB / ${total}MiB"
    else
        echo "Unknown"
    fi
}

get_disk_usage() {
    local root_usage=$(df -h / 2>/dev/null | tail -1 | awk '{print $3 "/" $2 " (" $5 ")"}')
    echo "$root_usage"
}

get_gpu() {
    lspci 2>/dev/null | grep -i vga | head -1 | cut -d: -f3 | sed 's/^ *//' | sed 's/Corporation //g; s/Controller //g' | xargs
}

get_resolution() {
    if command -v xrandr &>/dev/null && [[ -n "$DISPLAY" ]]; then
        xrandr 2>/dev/null | grep '*' | head -1 | awk '{print $1}'
    elif [[ -f /sys/class/drm/card0-eDP-1/modes ]]; then
        head -1 /sys/class/drm/card0-eDP-1/modes 2>/dev/null
    else
        echo "Unknown"
    fi
}

get_theme() {
    local gtk_theme=""
    if [[ -f "$HOME/.config/gtk-3.0/settings.ini" ]]; then
        gtk_theme=$(grep "gtk-theme-name" "$HOME/.config/gtk-3.0/settings.ini" 2>/dev/null | cut -d= -f2)
    fi
    if [[ -z "$gtk_theme" ]] && [[ -f "$HOME/.gtkrc-2.0" ]]; then
        gtk_theme=$(grep "gtk-theme-name" "$HOME/.gtkrc-2.0" 2>/dev/null | cut -d'"' -f2)
    fi
    echo "${gtk_theme:-Default}"
}

get_icons() {
    local icon_theme=""
    if [[ -f "$HOME/.config/gtk-3.0/settings.ini" ]]; then
        icon_theme=$(grep "gtk-icon-theme-name" "$HOME/.config/gtk-3.0/settings.ini" 2>/dev/null | cut -d= -f2)
    fi
    echo "${icon_theme:-Default}"
}

get_terminal() {
    if [[ -n "$TERM_PROGRAM" ]]; then
        echo "$TERM_PROGRAM"
    elif [[ -n "$TERMINAL" ]]; then
        echo "$TERMINAL"
    else
        echo "${TERM}"
    fi
}

get_local_ip() {
    ip route get 1.1.1.1 2>/dev/null | grep -oP 'src \K\S+' || echo "N/A"
}

get_battery() {
    if [[ -d /sys/class/power_supply/BAT0 ]]; then
        local capacity=$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null)
        local status=$(cat /sys/class/power_supply/BAT0/status 2>/dev/null)
        echo "${capacity}% (${status})"
    else
        echo "N/A"
    fi
}

# Print with color
print_info() {
    local label="$1"
    local value="$2"
    printf "${BOLD}${CYAN}%-12s${NC} %s\n" "$label" "$value"
}

# Main display
main() {
    rm -f "$CACHE_FILE"
    
    # Parse arguments
    local show_logo_flag=true
    local minimal=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-logo) show_logo_flag=false ;;
            --minimal) minimal=true ;;
            --help|-h)
                echo "Usage: rearch-fetch [OPTIONS]"
                echo ""
                echo "Options:"
                echo "  --no-logo     Don't display ASCII logo"
                echo "  --minimal     Show minimal information"
                echo "  --help, -h    Show this help message"
                exit 0
                ;;
        esac
        shift
    done
    
    [[ "$show_logo_flag" == true ]] && show_logo
    
    print_info "OS" "$(get_os)"
    print_info "Kernel" "$(get_kernel)"
    print_info "Uptime" "$(get_uptime)"
    print_info "Packages" "$(get_packages)"
    print_info "Shell" "$(get_shell)"
    print_info "DE/WM" "$(get_de_wm)"
    
    if [[ "$minimal" == false ]]; then
        echo ""
        print_info "CPU" "$(get_cpu)"
        print_info "CPU Cores" "$(get_cpu_cores)"
        print_info "Memory" "$(get_memory)"
        print_info "Disk (/)" "$(get_disk_usage)"
        print_info "GPU" "$(get_gpu)"
        print_info "Resolution" "$(get_resolution)"
        print_info "Theme" "$(get_theme)"
        print_info "Icons" "$(get_icons)"
        print_info "Terminal" "$(get_terminal)"
        print_info "Local IP" "$(get_local_ip)"
        local battery=$(get_battery)
        [[ "$battery" != "N/A" ]] && print_info "Battery" "$battery"
    fi
}

main "$@"
