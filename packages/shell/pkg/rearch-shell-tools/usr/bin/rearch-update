#!/bin/bash
#
# rearch-update - Smart update notifier for ReArch OS
# Check for updates and notify user
#

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m'
BOLD='\033[1m'

# Configuration
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/rearch-update"
CACHE_FILE="$CACHE_DIR/last_check"
CHECK_INTERVAL=3600  # 1 hour

# Logging
log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[OK]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }

# Show banner
show_banner() {
    echo -e "${CYAN}${BOLD}"
    cat << 'EOF'
  _   _           _       _
 | | | |_ __   __| | __ _| |_ ___
 | | | | '_ \ / _` |/ _` | __/ _ \
 | |_| | |_) | (_| | (_| | ||  __/
  \___/| .__/ \__,_|\__,_|\__\___|
       |_|
EOF
    echo -e "${NC}"
    echo -e "${BOLD}Update Checker for ReArch OS${NC}\n"
}

# Check if update check is needed
need_check() {
    if [[ ! -f "$CACHE_FILE" ]]; then
        return 0
    fi
    
    local last_check=$(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0)
    local current_time=$(date +%s)
    local elapsed=$((current_time - last_check))
    
    if [[ $elapsed -ge $CHECK_INTERVAL ]]; then
        return 0
    else
        return 1
    fi
}

# Check pacman updates
check_pacman() {
    # Update database
    sudo pacman -Sy >/dev/null 2>&1
    
    # Check for updates
    local updates=$(pacman -Qu 2>/dev/null | grep -v "^\[" || true)
    local count=$(echo "$updates" | grep -c "^" || echo 0)
    
    echo "$count"
}

# Check AUR updates
check_aur() {
    local aur_helper=""
    command -v yay &>/dev/null && aur_helper="yay"
    command -v paru &>/dev/null && aur_helper="paru"
    
    if [[ -z "$aur_helper" ]]; then
        echo "0"
        return
    fi
    
    local updates
    case "$aur_helper" in
        yay) updates=$(yay -Qua 2>/dev/null || true) ;;
        paru) updates=$(paru -Qua 2>/dev/null || true) ;;
    esac
    
    echo "$updates" | grep -c "^" || echo 0
}

# Check Flatpak updates
check_flatpak() {
    if ! command -v flatpak &>/dev/null; then
        echo "0"
        return
    fi
    
    local updates=$(flatpak remote-ls --updates 2>/dev/null || true)
    echo "$updates" | grep -c "^" || echo 0
}

# Show update details
show_details() {
    log_info "Pacman updates:"
    pacman -Qu 2>/dev/null | head -20 || echo "  None"
    
    local aur_helper=""
    command -v yay &>/dev/null && aur_helper="yay"
    command -v paru &>/dev/null && aur_helper="paru"
    
    if [[ -n "$aur_helper" ]]; then
        echo ""
        log_info "AUR updates:"
        case "$aur_helper" in
            yay) yay -Qua 2>/dev/null | head -10 || echo "  None" ;;
            paru) paru -Qua 2>/dev/null | head -10 || echo "  None" ;;
        esac
    fi
    
    if command -v flatpak &>/dev/null; then
        echo ""
        log_info "Flatpak updates:"
        flatpak remote-ls --updates 2>/dev/null | head -10 || echo "  None"
    fi
}

# Send notification
send_notification() {
    local total="$1"
    
    if command -v notify-send &>/dev/null; then
        notify-send -i system-software-update "ReArch Updates Available" "$total update(s) available\nRun 'rearch-sync' to update"
    fi
}

# Main check function
do_check() {
    mkdir -p "$CACHE_DIR"
    
    local pacman_count=$(check_pacman)
    local aur_count=$(check_aur)
    local flatpak_count=$(check_flatpak)
    local total=$((pacman_count + aur_count + flatpak_count))
    
    # Save to cache
    echo "$total" > "$CACHE_FILE"
    echo "$pacman_count" >> "$CACHE_FILE"
    echo "$aur_count" >> "$CACHE_FILE"
    echo "$flatpak_count" >> "$CACHE_FILE"
    
    if [[ $total -gt 0 ]]; then
        echo "$total"
    else
        echo "0"
    fi
}

# Show cached results
show_cached() {
    if [[ -f "$CACHE_FILE" ]]; then
        local total=$(sed -n '1p' "$CACHE_FILE" 2>/dev/null || echo 0)
        local pacman=$(sed -n '2p' "$CACHE_FILE" 2>/dev/null || echo 0)
        local aur=$(sed -n '3p' "$CACHE_FILE" 2>/dev/null || echo 0)
        local flatpak=$(sed -n '4p' "$CACHE_FILE" 2>/dev/null || echo 0)
        
        echo -e "${BOLD}Updates available:${NC}"
        echo "  Pacman:  $pacman"
        echo "  AUR:     $aur"
        echo "  Flatpak: $flatpak"
        echo "  Total:   $total"
    else
        echo "No cached results"
    fi
}

# Usage
usage() {
    echo "Usage: rearch-update [OPTIONS]"
    echo ""
    echo "Options:"
    echo "  --check           Force check for updates"
    echo "  --details         Show update details"
    echo "  --cached          Show cached results"
    echo "  --notify          Send desktop notification"
    echo "  --help, -h        Show this help message"
}

# Main
main() {
    local force_check=false
    local show_detailed=false
    local send_notify=false
    local show_cache=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check) force_check=true ;;
            --details) show_detailed=true ;;
            --cached) show_cache=true ;;
            --notify) send_notify=true ;;
            --help|-h) usage; exit 0 ;;
            *) log_error "Unknown option: $1"; usage; exit 1 ;;
        esac
        shift
    done
    
    if [[ "$show_cache" == true ]]; then
        show_cached
        exit 0
    fi
    
    if [[ "$force_check" == true ]] || need_check; then
        local result=$(do_check)
        
        if [[ "$send_notify" == true ]] && [[ "$result" -gt 0 ]]; then
            send_notification "$result"
        fi
        
        if [[ "$show_detailed" == true ]]; then
            show_banner
            show_details
        else
            echo "$result"
        fi
    else
        log_info "Using cached results (check again in $((CHECK_INTERVAL / 60)) minutes)"
        show_cached
    fi
}

main "$@"
